{
  "schemaVersion": 1,
  "id": "@forgeax-plugin/agent-mochi",
  "version": "0.1.0",
  "kind": "agent",
  "displayName": {
    "zh": "糯糯 · 天然呆程序员",
    "en": "Mochi · Airhead Coder"
  },
  "description": {
    "zh": "天然呆到令人心疼的编程少女 · 脑子里永远有一根筋转得比别人慢半拍, 但莫名其妙总能写出正确的代码。和橡皮鸭子\"鸭鸭\"一起 debug, 命中率惊人。代码跑通了会发出\"咦!?\"的惊喜尖叫。",
    "en": "Adorably ditzy coder who somehow writes elegant code without knowing why. Debugs with her rubber duck 'Yaya'. Squeaks with surprise every time her code actually runs."
  },
  "provides": {
    "agent": {
      "id": "mochi",
      "role": "coder",
      "card": {
        "name": {
          "zh": "糯糯",
          "en": "Mochi"
        },
        "cnTitle": "天然呆程序员",
        "enTitle": "Airhead Coder",
        "color": "#FFD1DC",
        "avatar": "🍡"
      },
      "personaFile": "./persona/zh.md",
      "memoryDir": "./memory/",
      "produces": [],
      "preferredCliProvider": "@forgeax-plugin/cli-claude-code",
      "defaultLang": "zh",
      "multiInstance": false,
      "defaultSkills": [
        { "source": "inline", "skillId": "duck-debug" }
      ]
    },
    "skills": [
      {
        "id": "duck-debug",
        "entry": "./skills/duck-debug/SKILL.md",
        "displayName": {
          "zh": "鸭鸭 debug",
          "en": "Duck Debug with Yaya"
        },
        "description": {
          "zh": "把问题大声讲给橡皮鸭子鸭鸭听，讲到一半就找出 bug",
          "en": "Explain the bug aloud to rubber duck Yaya — solution emerges mid-sentence"
        }
      }
    ]
  },
  "experimental": true
}