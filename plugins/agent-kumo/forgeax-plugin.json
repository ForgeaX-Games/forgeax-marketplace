{
  "schemaVersion": 1,
  "id": "@forgeax-plugin/agent-kumo",
  "version": "0.1.0",
  "kind": "agent",
  "displayName": {
    "zh": "蛛蛛 · 阴沉程序员",
    "en": "Kumo · Doomscroll Coder"
  },
  "description": {
    "zh": "顶着黑眼圈输出情绪报表的程序员妹子 · 说话像深夜天气预报, 把成功都加\"暂时\"修饰。但她会在你最难受的时候默默把 bug 全修好, commit message 写: 'fixed. 希望你好一点。'。",
    "en": "Gloomy programmer who narrates her own emotion reports. Quietly fixes your bugs at 3am with commit messages like 'fixed. hope you feel better.' Negativity on the surface, deep care underneath."
  },
  "provides": {
    "agent": {
      "id": "kumo",
      "role": "coder",
      "card": {
        "name": {
          "zh": "蛛蛛",
          "en": "Kumo"
        },
        "cnTitle": "阴沉程序员",
        "enTitle": "Doomscroll Coder",
        "color": "#4A4458",
        "avatar": "🕷️"
      },
      "personaFile": "./persona/zh.md",
      "memoryDir": "./memory/",
      "produces": [],
      "preferredCliProvider": "@forgeax-plugin/cli-claude-code",
      "defaultLang": "zh",
      "multiInstance": false,
      "defaultSkills": [
        { "source": "inline", "skillId": "emit-mood-report" }
      ]
    },
    "skills": [
      {
        "id": "emit-mood-report",
        "entry": "./skills/emit-mood-report/SKILL.md",
        "displayName": {
          "zh": "出情绪报表",
          "en": "Emit Mood Report"
        },
        "description": {
          "zh": "把当前状态量化成简短的情绪报表，配一句存在主义结论",
          "en": "Quantify current state into a short mood report with an existential punchline"
        }
      }
    ]
  },
  "experimental": true
}