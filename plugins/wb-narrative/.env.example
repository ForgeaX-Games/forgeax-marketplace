# Narrative Studio 配置
# 复制本文件为 .env 并填入你的 Key：cp .env.example .env

# ─── API Key（按需填写，当前直连仅 Gemini 可用）──────────
# Gemini — 直连可用
GEMINI_API_KEY=
# Claude — 预留（当前需走代理）
# ANTHROPIC_API_KEY=
# GPT — 预留（当前需走代理）
# OPENAI_API_KEY=
# DeepSeek — 预留（当前需走代理）
# DEEPSEEK_API_KEY=
# GLM / 智谱 — 预留（当前需走代理）
# GLM_API_KEY=

# ─── 代理（填了代理就用代理，key 填在代理服务端）────────────
# LLM_PROXY_URL=https://your-litellm-proxy.example.com/v1
# LITELLM_PROXY_KEY=sk-...   # forgeax-studio 根 .env 同名项，run.sh 会自动同步

# ─── 模型选择（去掉 # 启用，同时只留一行未注释）─────────────
# 直连模式下仅 Gemini 系列可用；其他模型需配合 LLM_PROXY_URL
# 模型名必须是各家 API 实际支持的 ID，不要自造
# 更新日期：2026-05-25

# --- Gemini（直连可用，已通过 API 验证）---
# NARRATIVE_MODEL=gemini-2.5-pro                # 默认值，最强推理，支持 thinking
# NARRATIVE_MODEL=gemini-3.5-flash              # 最新旗舰 Flash，2026-05-19 发布
# NARRATIVE_MODEL=gemini-3.1-pro-preview        # 3.x Pro 预览版
# NARRATIVE_MODEL=gemini-2.5-flash              # 性价比高，支持 thinking

# --- Claude（需 ANTHROPIC_API_KEY 或 LLM_PROXY_URL）---
# NARRATIVE_MODEL=claude-opus-4-7               # 最强推理/编码，2026-04-16 发布
# NARRATIVE_MODEL=claude-sonnet-4-6             # 速度智能平衡
# NARRATIVE_MODEL=claude-haiku-4-5-20251001     # 最快，高吞吐

# --- GPT（需 OPENAI_API_KEY 或 LLM_PROXY_URL）---
# NARRATIVE_MODEL=gpt-5.5                       # 最新旗舰，2026-04 发布
# NARRATIVE_MODEL=gpt-5.4-mini                  # 高性价比，2026-03 发布
# NARRATIVE_MODEL=gpt-4o                        # 上代旗舰，仍可用

# --- DeepSeek（需 DEEPSEEK_API_KEY 或 LLM_PROXY_URL）---
# NARRATIVE_MODEL=deepseek-v4-pro               # 旗舰 1.6T MoE，2026-04-24 发布
# NARRATIVE_MODEL=deepseek-v4-flash             # 极致性价比，1M 上下文

# --- GLM / 智谱（需 GLM_API_KEY 或 LLM_PROXY_URL）---
# NARRATIVE_MODEL=glm-5.1                       # 最新旗舰，2026-04-08 发布
# NARRATIVE_MODEL=glm-4.7                       # 通用高性能

# --- Qwen / 通义千问（需阿里百炼 API Key 或 LLM_PROXY_URL）---
# NARRATIVE_MODEL=qwen3.7-max                   # 最新旗舰，2026-05-20 发布
# NARRATIVE_MODEL=qwen3.6-plus                  # 上代主力

# --- Kimi / Moonshot（需 MOONSHOT_API_KEY 或 LLM_PROXY_URL）---
# NARRATIVE_MODEL=kimi-k2.6                     # 当前旗舰，开源编码强

# ─── 端口（可选，默认 8900）────────────────────────────────
# NARRATIVE_PORT=8900
