{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "status"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["running", "completed", "failed"]
    },
    "progress": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "stepId": { "type": "string" },
          "label": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "running", "completed", "failed"] }
        }
      },
      "description": "Step-level progress entries"
    },
    "error": {
      "type": "string",
      "description": "Error message when status is 'failed'"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "tier": { "type": "string" },
    "mode": { "type": "string" },
    "result": {
      "type": "object",
      "description": "Full NarrativeContext when includeResult=true and status=completed"
    }
  }
}
