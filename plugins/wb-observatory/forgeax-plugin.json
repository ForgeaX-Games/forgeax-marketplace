{
  "schemaVersion": 1,
  "id": "@forgeax-plugin/wb-observatory",
  "version": "0.1.0",
  "kind": "workbench",
  "displayName": {
    "zh": "Observatory · 轨迹观察台",
    "en": "Observatory"
  },
  "description": {
    "zh": "实时/离线查看 agent 与子 agent 的 turn / tool / sub-agent 轨迹与 system-prompt 模块切片，辅助上下文 / skill / 护栏 / cache 管理。",
    "en": "Live + static visualization of agent and sub-agent turns, tool calls, and system-prompt module slices. Aids context / skill / guardrail / cache management."
  },
  "author": { "name": "forgeax", "email": "dev@forgeax.local" },
  "icon": "🔭",
  "keywords": ["observatory", "agent", "sub-agent", "trace", "sse", "reactflow", "context", "system-prompt"],

  "provides": {
    "workbench": {
      "id": "wb-observatory",
      "icon": "🔭",
      "position": 150,
      "panelSize": "lg",
      "surface": "single"
    }
  },

  "entry": {
    "frontend": "./dist/index.html",
    "standalone": {
      "start": "false",
      "port": 0,
      "readyProbe": "/",
      "embeddedAlso": true,
      "devOnly": false
    }
  },

  "permissions": [
    "fs:read:~/.forgeax/sessions/**"
  ],

  "experimental": true,
  "compatibleWith": { "forgeax-bus": "^1.0.0" }
}
