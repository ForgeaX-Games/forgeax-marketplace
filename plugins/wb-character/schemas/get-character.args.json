{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "charId"],
  "additionalProperties": false,
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,40}$" },
    "charId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,40}$" }
  }
}
