{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "charId": { "type": "string" },
          "name": { "type": "string" },
          "portraitUrl": { "type": "string" },
          "createdAt": { "type": "string" },
          "hasSprites": { "type": "boolean" }
        }
      }
    },
    "slug": { "type": "string" }
  }
}
