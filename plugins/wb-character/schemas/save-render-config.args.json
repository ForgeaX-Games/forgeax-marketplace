{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "description": "CharacterRenderParams snapshot — position/scale/billboard/material/chromaKey",
  "properties": {
    "posX": { "type": "number" },
    "posY": { "type": "number" },
    "posZ": { "type": "number" },
    "scale": { "type": "number" },
    "rotY": { "type": "number" },
    "billboard": { "type": "boolean" },
    "opacity": { "type": "number" },
    "brightness": { "type": "number" },
    "contrast": { "type": "number" },
    "saturation": { "type": "number" },
    "tintColor": { "type": "string" },
    "tintStrength": { "type": "number" },
    "chromaKey": { "type": ["object", "null"], "additionalProperties": true }
  }
}
