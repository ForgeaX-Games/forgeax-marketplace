{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "charId"],
  "additionalProperties": true,
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9_][a-z0-9-_]{1,40}$" },
    "charId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,40}$" },
    "prompt": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "params": { "type": "object", "description": "Pipeline-specific parameters; see SKILL.md for shapes" }
  }
}
