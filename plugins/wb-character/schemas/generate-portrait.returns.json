{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["charId", "files"],
  "additionalProperties": false,
  "properties": {
    "charId": { "type": "string" },
    "name": { "type": "string" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["view", "path", "url"],
        "properties": {
          "view": { "type": "string", "enum": ["front", "side", "back"] },
          "path": { "type": "string", "description": "friendlyPath() relative to projectRoot" },
          "url": { "type": "string", "description": "/api/files endpoint that streams the bytes" }
        }
      }
    },
    "manifestPath": { "type": "string" },
    "model": { "type": "string" },
    "costEstimate": {
      "type": "object",
      "properties": {
        "usd": { "type": "number" },
        "vendor": { "type": "string" }
      }
    }
  }
}
