# ═══════════════════════════════════════════════════
# Character Editor — 环境变量模板
# 复制此文件为 .env 并填入你自己的密钥
# cp .env.example .env
# ═══════════════════════════════════════════════════

# ── Azure Claude (Anthropic) ──
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_API_BASE=https://your-azure-endpoint.services.ai.azure.com/anthropic/v1/messages

# ── Kling (视频生成) ──
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key

# ── MCP 服务配置（可选） ──
# MCP_HOST=vag-mcp-sandbox
# MCP_PROMPT_PORT=3101
# MCP_PIXELART_PORT=3105

# ── 音乐搜索（内网，可选） ──
# AW_API_BASE_URL=http://your-internal-api:8008
# AW_API_SANDBOX_KEY=your-sandbox-key
