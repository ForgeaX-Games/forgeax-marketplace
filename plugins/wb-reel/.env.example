# Reel-Studio 模型/服务 key（本地用，**永远不要 commit**）
#
# vite.config.ts 按以下优先级**第一个找到**的为准：
#   1. process.env.KS_LLM_KEY_PATH         ← 显式指定（最高优先）
#   2. ./key/llm_key.json                  ← 独立仓库下本地放 key（已 .gitignore）
#
# llm_key.json 期望结构：
# {
#   "azure-claude":         { "api_key": "...", "api_base": "https://<resource>.services.ai.azure.com/anthropic" },
#   "azure-openai-image":   { "api_key": "...", "api_base": "https://<resource>.cognitiveservices.azure.com",
#                             "api_version": "2024-02-01" }
# }
#
# 任一缺失/全部缺失时，对应模块自动退化为 MockProvider —— 编辑器仍可离线使用。

# 浏览器访问的宿主端口（独立仓库下默认 vite 端口 15175）
# PORT_REEL_STUDIO=10052

# 显式指定 key 文件位置（少见，通常用候选 #2 即可）
# KS_LLM_KEY_PATH=/absolute/path/to/llm_key.json

# 公共分发构建（强制清空所有 key）
# RS_NO_KEY=1
