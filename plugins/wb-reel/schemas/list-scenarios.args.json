{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reel:list-scenarios args",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200,
      "description": "Max number of scenarios to return (default 50)."
    },
    "offset": {
      "type": "integer",
      "minimum": 0,
      "description": "Skip the first N scenarios (default 0)."
    }
  }
}
