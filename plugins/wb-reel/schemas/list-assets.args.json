{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reel:list-assets args",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["image", "video"],
      "description": "Filter by asset kind."
    },
    "scenarioId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{1,64}$",
      "description": "Filter to assets created for a specific scenario (matches meta.scenarioId)."
    },
    "limit": { "type": "integer", "minimum": 1, "maximum": 500 }
  }
}
