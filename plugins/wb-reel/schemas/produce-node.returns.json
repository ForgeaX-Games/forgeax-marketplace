{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reel:produce-node returns",
  "type": "object",
  "additionalProperties": true,
  "required": ["ok"],
  "properties": {
    "ok": { "type": "boolean" },
    "sceneId": { "type": "string" },
    "sceneIds": { "type": "array", "items": { "type": "string" } },
    "scope": { "type": "string", "enum": ["node", "firstN", "all"] },
    "count": { "type": "integer" },
    "stages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "message": { "type": "string" }
  }
}
