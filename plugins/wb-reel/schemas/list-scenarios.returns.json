{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reel:list-scenarios returns",
  "type": "object",
  "additionalProperties": true,
  "required": ["scenarios"],
  "properties": {
    "activeId": { "type": ["string", "null"] },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": ["string", "null"] },
          "sceneCount": { "type": "integer" },
          "updatedAt": { "type": "number" },
          "lastPublishedAt": { "type": ["number", "null"] }
        }
      }
    }
  }
}
