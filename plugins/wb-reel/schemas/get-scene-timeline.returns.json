{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reel:get-scene-timeline returns",
  "description": "Compact timeline of one scene. All times are ms relative to the scene start.",
  "type": "object",
  "properties": {
    "scenarioId": { "type": "string" },
    "sceneId": { "type": "string" },
    "durationMs": { "type": "number", "description": "Total timeline length of the scene (ms)." },
    "shots": {
      "type": "array",
      "description": "Storyboard shots in order. speed: 1=normal, 0=freeze, 0.5..2=slow/fast.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "order": { "type": "number" },
          "startMs": { "type": "number" },
          "endMs": { "type": "number" },
          "speed": { "type": "number" },
          "framing": { "type": "string" },
          "transitionIn": { "type": ["object", "null"] },
          "clipAnim": { "type": ["object", "null"] }
        }
      }
    },
    "dialogue": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "role": { "type": "string" },
          "speaker": { "type": "string" },
          "text": { "type": "string" },
          "startMs": { "type": "number" },
          "endMs": { "type": "number" }
        }
      }
    },
    "qteCues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "shape": { "type": "string" },
          "appearAt": { "type": "number" },
          "targetAt": { "type": "number" },
          "label": { "type": "string" }
        }
      }
    },
    "audio": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "role": { "type": "string" },
          "ref": { "type": "string" },
          "startMs": { "type": "number" },
          "durationMs": { "type": "number" },
          "volume": { "type": "number" },
          "fadeInMs": { "type": "number" },
          "fadeOutMs": { "type": "number" }
        }
      }
    },
    "textOverlays": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "startMs": { "type": "number" },
          "endMs": { "type": "number" },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    },
    "markers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "ms": { "type": "number" },
          "label": { "type": "string" }
        }
      }
    }
  }
}
