{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reel:import-from-narrative returns",
  "type": "object",
  "properties": {
    "ok": { "type": "boolean" },
    "scenarioId": { "type": "string", "description": "The generated scenario ID" },
    "title": { "type": "string" },
    "sceneCount": { "type": "number", "description": "Number of scenes imported" },
    "activeId": { "type": ["string", "null"] },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-fatal conversion warnings"
    }
  }
}
