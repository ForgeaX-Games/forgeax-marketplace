{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "wb-reel.scenario",
  "description": "Surface snapshot for the active scenario in Reel Studio. UI pushes this to host so AI can observe without read-locking the editor store.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "activeScenarioId": { "type": ["string", "null"] },
    "title":            { "type": ["string", "null"] },
    "sceneCount":       { "type": ["integer", "null"] },
    "activeTab":        { "type": ["string", "null"], "enum": ["forge", "player", null] },
    "mode":             { "type": ["string", "null"], "enum": ["editor", "player", null] },
    "selectedSceneId":  { "type": ["string", "null"] },
    "runningVideoTasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "taskId": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  }
}
