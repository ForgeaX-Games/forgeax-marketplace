{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reel:save-scenario args",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenario"],
  "properties": {
    "scenario": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title", "rootSceneId", "scenes", "defaultCharMs", "schemaVersion"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$",
          "description": "Unique scenario id (kebab-case slug)"
        },
        "title": { "type": "string", "description": "Display title" },
        "synopsis": { "type": "string", "description": "One-line synopsis for the player" },
        "rootSceneId": { "type": "string", "description": "Id of the first scene (entry point)" },
        "scenes": {
          "type": "object",
          "description": "Dict keyed by scene id → Scene object. NOT an array.",
          "additionalProperties": {
            "type": "object",
            "required": ["id", "title", "media", "durationMs", "dialogue", "branches"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string", "description": "Scene display title" },
              "media": {
                "type": "object",
                "required": ["kind"],
                "properties": {
                  "kind": { "type": "string", "enum": ["VIDEO", "IMAGE_PROMPT", "IMAGE_STATIC", "PLACEHOLDER"] },
                  "ref": { "type": "string", "description": "Asset id or URL (optional for IMAGE_PROMPT/PLACEHOLDER)" },
                  "prompt": { "type": "string", "description": "Image/video generation prompt (for IMAGE_PROMPT kind)" }
                }
              },
              "durationMs": { "type": "number", "description": "Scene total duration in ms (e.g. 8000 = 8s)" },
              "dialogue": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "role", "text", "startMs"],
                  "properties": {
                    "id": { "type": "string" },
                    "role": { "type": "string", "enum": ["narration", "protagonist", "character", "system"] },
                    "speaker": { "type": "string" },
                    "text": { "type": "string" },
                    "startMs": { "type": "number" }
                  }
                }
              },
              "qte": {
                "type": ["object", "null"],
                "description": "QTE spec (optional). Contains cues[], window{perfect,great,good}, score{}."
              },
              "branches": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "kind", "targetSceneId"],
                  "properties": {
                    "id": { "type": "string" },
                    "label": { "type": "string", "description": "Choice text (for kind=choice)" },
                    "kind": { "type": "string", "enum": ["choice", "qte_pass", "qte_fail", "auto"] },
                    "targetSceneId": { "type": "string", "description": "Target scene id to jump to" }
                  }
                }
              }
            }
          }
        },
        "defaultCharMs": { "type": "number", "default": 50, "description": "Typewriter speed: ms per character" },
        "schemaVersion": { "type": "number", "enum": [1, 2, 3, 4, 5], "default": 1, "description": "Data schema version" },
        "characters": {
          "type": "object",
          "description": "Character dict keyed by character id (optional)"
        },
        "locations": {
          "type": "object",
          "description": "Location dict keyed by location id (optional)"
        }
      },
      "description": "Full Scenario object. scenes must be a Record<sceneId, Scene> (dict, NOT array). Server enforces id regex."
    },
    "setActive": {
      "type": "boolean",
      "default": true,
      "description": "Mark this scenario as the active one (shown in workbench on open/refresh). Defaults to true; pass false only for background/batch saves."
    }
  }
}
