{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reel:edit-qte returns",
  "description": "Result of a QTE cue add/update/remove.",
  "type": "object",
  "properties": {
    "scenarioId": { "type": "string" },
    "sceneId": { "type": "string" },
    "op": { "type": "string" },
    "id": { "type": "string", "description": "Affected cue id (the new id for add)." },
    "cueCount": { "type": "number", "description": "Cue count after the edit." },
    "updatedAt": { "type": "number" },
    "ok": { "type": "boolean" }
  }
}
