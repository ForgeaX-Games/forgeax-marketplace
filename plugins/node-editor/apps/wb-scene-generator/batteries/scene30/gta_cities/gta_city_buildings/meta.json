{
  "id": "gta_city_buildings",
  "label": "GTA 城市建筑足迹",
  "description": "在道路地块内生成矩形建筑足迹，商业密集、住宅中等、工业大盒、郊区稀疏。",
  "description-en": "Places rectangular building footprints inside parcels: dense CBD, medium residential, large industrial boxes, and sparse suburbs.",
  "icon": "道路围合地块内排列灰色方盒建筑。",
  "version": "1.0.0",
  "tags": ["gta", "city", "building", "footprint", "parcel"],
  "tag_labels": ["GTA", "城市", "建筑", "足迹"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "districtGrid", "type": "grid", "label": "功能片区" },
    { "name": "roadGrid", "type": "grid", "label": "完整道路" },
    { "name": "parcelGrid", "type": "grid", "label": "地块网格" },
    { "name": "seed", "type": "number", "label": "随机种子", "default": 20260615 },
    { "name": "density", "type": "number", "label": "建筑密度", "default": 0.68, "min": 0, "max": 1 },
    { "name": "minRoadDist", "type": "number", "label": "最小临路距离", "default": 2, "min": 0, "max": 16 },
    { "name": "maxRoadDist", "type": "number", "label": "最大临路距离", "default": 18, "min": 3, "max": 80 }
  ],
  "outputs": [
    { "name": "buildingGrid", "type": "grid", "label": "建筑网格" },
    { "name": "outputGrid", "type": "grid", "label": "建筑预览" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
