{
  "id": "gta_city_streets",
  "label": "GTA 城市街巷",
  "description": "在不同功能区内生成局部街巷网格，商业区密集、住宅区中等、工业和郊区更疏。",
  "description-en": "Generates local street fabrics per district, with dense CBD streets and sparser industrial/suburban roads.",
  "icon": "主干路之间填充局部街区道路。",
  "version": "1.0.0",
  "tags": ["gta", "city", "street", "block", "urban"],
  "tag_labels": ["GTA", "城市", "街巷", "街区"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "districtGrid", "type": "grid", "label": "功能片区" },
    { "name": "arterialGrid", "type": "grid", "label": "主干路" },
    { "name": "roadGrid", "type": "grid", "label": "已有道路" },
    { "name": "seed", "type": "number", "label": "随机种子", "default": 20260613 },
    { "name": "baseSpacing", "type": "number", "label": "基础街距", "default": 30, "min": 8, "max": 120 },
    { "name": "roadWidth", "type": "number", "label": "街巷宽度", "default": 0, "min": 0, "max": 4 },
    { "name": "density", "type": "number", "label": "街巷密度", "default": 0.74, "min": 0, "max": 1 }
  ],
  "outputs": [
    { "name": "streetGrid", "type": "grid", "label": "街巷" },
    { "name": "roadGrid", "type": "grid", "label": "完整道路" },
    { "name": "outputGrid", "type": "grid", "label": "道路预览" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
