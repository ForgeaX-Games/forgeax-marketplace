{
  "id": "complex_indoor_deform",
  "label": "复杂室内房间变形",
  "description": "将矩形房间变形为异形房间（L/T/U形），填充空隙，增加紧凑度",
  "description-en": "Deforms rectangular rooms into irregular shapes (L/T/U) by extending into adjacent void pockets.",
  "icon": "一个矩形变成L形的变化过程图标，深灰背景白色填充，扁平插画风格简洁小图标主色2种",
  "version": "1.0.0",
  "tags": ["indoor", "deform", "irregular", "compact"],
  "tag_labels": ["室内", "变形", "异形", "紧凑"],
  "inputs": [
    { "name": "inputGrid", "type": "grid", "label": "输入网格", "description": "包含所有房间的网格", "description-en": "Grid with all rooms" },
    { "name": "roomList", "type": "array", "label": "房间列表", "description": "房间数据", "description-en": "Room data" },
    { "name": "connectionList", "type": "array", "label": "连接列表", "description": "房间连接关系", "description-en": "Room connections" },
    { "name": "deformProb", "type": "number", "label": "变形概率", "description": "每个房间变形的概率(0~1)", "description-en": "Probability of deforming each room (0-1)", "default": 0.5 },
    { "name": "maxExtPerRoom", "type": "number", "label": "每房间最大扩展数", "description": "每个房间最多尝试几次扩展", "description-en": "Max extensions per room", "default": 2 },
    { "name": "minExtDim", "type": "number", "label": "最小扩展尺寸", "description": "扩展块内部最小边长", "description-en": "Min inner dimension of extension", "default": 2 },
    { "name": "seed", "type": "number", "label": "随机种子", "description": "随机种子，0使用当前时间戳", "description-en": "Random seed; 0 uses timestamp", "default": 0 }
  ],
  "outputs": [
    { "name": "outputGrid", "type": "grid", "label": "输出网格", "description": "含异形房间的网格", "description-en": "Grid with deformed rooms" },
    { "name": "roomList", "type": "array", "label": "房间列表", "description": "更新后的房间数据", "description-en": "Updated room data" },
    { "name": "connectionList", "type": "array", "label": "连接列表", "description": "更新后的连接关系", "description-en": "Updated connections" }
  ]
}
