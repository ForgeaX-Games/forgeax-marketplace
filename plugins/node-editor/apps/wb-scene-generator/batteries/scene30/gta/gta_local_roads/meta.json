{
  "id": "gta_local_roads",
  "label": "GTA 小路补全",
  "description": "在住宅/商业街区内生成短小的局部道路，补齐建筑地块入口，但避免覆盖主干路结构。",
  "description-en": "Adds short local streets inside residential/commercial districts to create building parcels without overwhelming arterials.",
  "icon": "街区内部的小路把大地块切成可放建筑的方形小地块。",
  "version": "1.0.0",
  "tags": ["gta", "local-road", "parcel"],
  "tag_labels": ["GTA", "小路", "地块"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "zoneGrid", "type": "grid", "label": "功能区网格" },
    { "name": "roadGrid", "type": "grid", "label": "主路+辅路" },
    { "name": "heightMap", "type": "grid", "label": "高度图" },
    { "name": "seed", "type": "number", "label": "随机种子", "default": 20260605 },
    { "name": "spacing", "type": "number", "label": "小路间距", "default": 28, "min": 10, "max": 80 },
    { "name": "coverage", "type": "number", "label": "补路覆盖", "default": 0.52, "min": 0, "max": 1 },
    { "name": "connectRadius", "type": "number", "label": "连通桥接半径", "default": 120, "min": 0, "max": 400 }
  ],
  "outputs": [
    { "name": "roadGrid", "type": "grid", "label": "完整道路" },
    { "name": "localRoadGrid", "type": "grid", "label": "小路网格" },
    { "name": "outputGrid", "type": "grid", "label": "完整道路预览" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
