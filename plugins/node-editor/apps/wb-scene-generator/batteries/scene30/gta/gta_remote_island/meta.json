{
  "id": "gta_remote_island",
  "label": "GTA 远海海岛",
  "description": "在远离大陆的海域生成一个独立海岛，岛内包含简单功能分区和自有道路系统。",
  "description-en": "Generates a standalone island in open water, with simple internal districts and its own road network.",
  "icon": "远离大陆的小岛，内部有环路、中心区和几条连接道路。",
  "version": "1.0.0",
  "tags": ["gta", "island", "remote", "district", "road"],
  "tag_labels": ["GTA", "海岛", "远海", "分区", "道路"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "landGrid", "type": "grid", "label": "现有陆地掩码" },
    { "name": "avoidMask", "type": "grid", "label": "避让掩码" },
    { "name": "seed", "type": "number", "label": "随机种子", "default": 20260609 },
    { "name": "radius", "type": "number", "label": "岛屿半径", "default": 58, "min": 18, "max": 140 },
    { "name": "roadWidth", "type": "number", "label": "道路宽度", "default": 1, "min": 1, "max": 5 },
    { "name": "districtCount", "type": "number", "label": "分区数量", "default": 5, "min": 3, "max": 9 }
  ],
  "outputs": [
    { "name": "islandGrid", "type": "grid", "label": "海岛综合网格" },
    { "name": "islandLandGrid", "type": "grid", "label": "海岛陆地" },
    { "name": "islandZoneGrid", "type": "grid", "label": "海岛分区" },
    { "name": "islandRoadGrid", "type": "grid", "label": "海岛道路" },
    { "name": "islandSite", "type": "object", "label": "海岛站点参数" },
    { "name": "outputGrid", "type": "grid", "label": "海岛预览" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
