{
  "id": "gta_main_roads",
  "label": "GTA 主路骨架",
  "description": "基于功能区生成连续主干路、环路和短桥，负责 GTA 地图中最粗的黑色交通骨架。",
  "description-en": "Generates continuous arterials, ring roads, and short bridges from functional zones as the main GTA road skeleton.",
  "icon": "城市岛屿上粗黑主干路、环路和跨水桥梁连接各区。",
  "version": "1.0.0",
  "tags": ["gta", "arterial", "road", "bridge"],
  "tag_labels": ["GTA", "主干路", "道路", "桥梁"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "zoneGrid", "type": "grid", "label": "功能区网格" },
    { "name": "buildableMask", "type": "grid", "label": "可建设掩码" },
    { "name": "landGrid", "type": "grid", "label": "陆地掩码" },
    { "name": "heightMap", "type": "grid", "label": "高度图" },
    { "name": "seed", "type": "number", "label": "随机种子", "default": 20260603 },
    { "name": "roadWidth", "type": "number", "label": "主路宽度", "default": 3, "min": 1, "max": 8 },
    { "name": "bridgeGap", "type": "number", "label": "最大桥接间隙", "default": 90, "min": 0, "max": 220 },
    { "name": "minIslandArea", "type": "number", "label": "最小连路岛屿面积", "default": 1200, "min": 0, "max": 20000,
      "description": "面积小于此值的小岛不接入道路网（最大陆块始终连接，超大岛屿视为大陆）。" }
  ],
  "outputs": [
    { "name": "mainRoadGrid", "type": "grid", "label": "主路网格" },
    { "name": "outputGrid", "type": "grid", "label": "主路预览" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
