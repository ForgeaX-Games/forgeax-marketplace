{
  "id": "gta_airport_outline",
  "label": "GTA 机场轮廓",
  "description": "在地图陆地边缘附近选择一块相对平坦的长条机场用地，输出机场掩码、轮廓线和站点参数。",
  "description-en": "Places a flat elongated airport site near the land/map edge and outputs the airport mask, outline, and site descriptor.",
  "icon": "靠近海岸或地图边缘的一块长条机场用地轮廓，像开放世界城市地图里的机场区域。",
  "version": "1.0.0",
  "tags": ["gta", "airport", "outline", "edge", "runway"],
  "tag_labels": ["GTA", "机场", "轮廓", "边缘", "跑道"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "landGrid", "type": "grid", "label": "陆地掩码" },
    { "name": "heightMap", "type": "grid", "label": "高度图" },
    { "name": "seed", "type": "number", "label": "随机种子", "default": 20260607 },
    { "name": "siteLength", "type": "number", "label": "机场长度", "default": 168, "min": 48, "max": 360 },
    { "name": "siteWidth", "type": "number", "label": "机场宽度", "default": 70, "min": 24, "max": 180 },
    { "name": "edgeInset", "type": "number", "label": "边缘退让", "default": 18, "min": 0, "max": 120 }
  ],
  "outputs": [
    { "name": "airportMask", "type": "grid", "label": "机场掩码" },
    { "name": "airportOutlineGrid", "type": "grid", "label": "机场轮廓" },
    { "name": "airportZoneGrid", "type": "grid", "label": "机场用地" },
    { "name": "airportSite", "type": "object", "label": "机场站点参数" },
    { "name": "outputGrid", "type": "grid", "label": "机场轮廓预览" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
