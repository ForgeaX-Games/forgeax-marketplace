{
  "id": "gta_harbor_area",
  "label": "GTA 码头区域",
  "description": "自动寻找海湾/凹入海岸，在水陆交界处生成港池、栈桥和码头陆地区；不生成道路。",
  "description-en": "Finds a bay-like coastline and generates a harbor basin, piers, and dock yard without creating roads.",
  "icon": "海湾水面边缘伸出多条平行栈桥，旁边是矩形码头陆地区。",
  "version": "1.0.0",
  "tags": ["gta", "harbor", "dock", "pier", "bay", "waterfront"],
  "tag_labels": ["GTA", "码头", "栈桥", "海湾", "滨水区"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "landGrid", "type": "grid", "label": "陆地掩码" },
    { "name": "heightMap", "type": "grid", "label": "高度图" },
    { "name": "cityRoadGrid", "type": "grid", "label": "城市道路网格" },
    { "name": "buildingGrid", "type": "grid", "label": "建筑网格" },
    { "name": "avoidMask", "type": "grid", "label": "避让掩码" },
    { "name": "seed", "type": "number", "label": "随机种子", "default": 20260608 },
    { "name": "pierCount", "type": "number", "label": "栈桥数量", "default": 5, "min": 2, "max": 12 },
    { "name": "pierLength", "type": "number", "label": "栈桥长度", "default": 74, "min": 16, "max": 180 },
    { "name": "harborWidth", "type": "number", "label": "码头宽度", "default": 126, "min": 40, "max": 260 },
    { "name": "yardDepth", "type": "number", "label": "陆地区深度", "default": 36, "min": 12, "max": 120 }
  ],
  "outputs": [
    { "name": "harborGrid", "type": "grid", "label": "码头区域" },
    { "name": "pierGrid", "type": "grid", "label": "栈桥网格" },
    { "name": "basinGrid", "type": "grid", "label": "港池网格" },
    { "name": "yardGrid", "type": "grid", "label": "码头陆地区" },
    { "name": "harborSite", "type": "object", "label": "码头站点参数" },
    { "name": "outputGrid", "type": "grid", "label": "码头区域预览" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
