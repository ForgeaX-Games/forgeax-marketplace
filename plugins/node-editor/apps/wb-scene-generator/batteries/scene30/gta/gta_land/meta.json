{
  "id": "gta_land",
  "label": "GTA 陆地",
  "description": "根据高度图和海平面阈值生成陆地掩码，并用元胞多数表决平滑海岸线。",
  "description-en": "Builds a land mask from a height map and sea level, then smooths coastlines with cellular majority voting.",
  "icon": "GTA 风格俯视海岸线，蓝色海洋包围绿色大陆，海岸边缘平滑处理。",
  "version": "1.0.0",
  "tags": ["gta", "land", "coast", "smooth", "mask"],
  "tag_labels": ["GTA", "陆地", "海岸", "平滑", "掩码"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "heightMap", "type": "grid", "label": "高度图" },
    { "name": "seaLevel", "type": "number", "label": "海平面", "default": 0.48, "min": 0, "max": 1 },
    { "name": "iterations", "type": "number", "label": "平滑次数", "default": 3, "min": 0, "max": 10 },
    { "name": "birthLimit", "type": "number", "label": "成陆阈值", "default": 5, "min": 1, "max": 8 }
  ],
  "outputs": [
    { "name": "landGrid", "type": "grid", "label": "陆地掩码" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
