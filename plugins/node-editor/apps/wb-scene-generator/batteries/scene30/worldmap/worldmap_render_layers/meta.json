{
  "id": "worldmap_render_layers",
  "label": "世界地图渲染分层",
  "description": "把高度、陆地、国家边界、城市、道路、机场跑道、码头区域、远海海岛、公园绿地与建筑合成为适合 renderer 展示的单值网格列表和名称清单。",
  "description-en": "Combines height, land, borders, cities, roads, airport runways, harbor areas, remote islands, and buildings into renderer-friendly single-value grid layers and a name list.",
  "icon": "多层世界地图图层叠加：海洋、陆地、边界、城市、道路。",
  "version": "1.0.0",
  "tags": ["worldmap", "render", "layer", "namelist", "output"],
  "tag_labels": ["世界地图", "渲染", "图层", "名称清单", "输出"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "heightMap", "type": "grid", "label": "高度图" },
    { "name": "landGrid", "type": "grid", "label": "陆地掩码" },
    { "name": "boundaryGrid", "type": "grid", "label": "边界网格" },
    { "name": "cityGrid", "type": "grid", "label": "城市网格" },
    { "name": "roadGrid", "type": "grid", "label": "道路网格" },
    { "name": "tunnelGrid", "type": "grid", "label": "海底隧道网格" },
    { "name": "harborGrid", "type": "grid", "label": "码头区域网格" },
    { "name": "islandGrid", "type": "grid", "label": "远海海岛网格" },
    { "name": "buildingGrid", "type": "grid", "label": "建筑网格" },
    { "name": "parkGrid", "type": "grid", "label": "公园绿地网格 (来自 gta_park_overlay)" }
  ],
  "outputs": [
    { "name": "outputGridList", "type": "array", "label": "输出网格列表" },
    { "name": "outputNameList", "type": "array", "label": "输出名称清单" },
    { "name": "outputGrid", "type": "grid", "label": "合并预览网格" }
  ]
}
