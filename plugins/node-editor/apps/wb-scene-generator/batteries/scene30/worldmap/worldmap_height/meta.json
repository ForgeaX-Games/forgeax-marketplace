{
  "id": "worldmap_height",
  "label": "世界地图高度图",
  "description": "使用多倍频值噪声和径向边缘衰减生成幻想世界地图高度场，输出高度图与早期海陆预览。",
  "description-en": "Generates a fantasy world height field with fBm value noise and radial falloff, plus an early land/ocean preview.",
  "icon": "俯视世界地图，高度等值色带从蓝色海洋过渡到绿色陆地和棕色山地，扁平小图标。",
  "version": "1.0.0",
  "tags": ["worldmap", "heightmap", "terrain", "noise", "continent"],
  "tag_labels": ["世界地图", "高度图", "地形", "噪声", "大陆"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "grid", "type": "grid", "label": "输入掩码", "description": "可选尺寸/掩码网格，非 0 区域生成高度；不接入时使用 width/height。"},
    { "name": "width", "type": "number", "label": "宽度", "default": 240 },
    { "name": "height", "type": "number", "label": "高度", "default": 140 },
    { "name": "seed", "type": "number", "label": "随机种子", "default": 12345 },
    { "name": "scale", "type": "number", "label": "特征尺度", "default": 4, "min": 1, "max": 16 },
    { "name": "octaves", "type": "number", "label": "倍频数", "default": 5, "min": 1, "max": 8 },
    { "name": "persistence", "type": "number", "label": "持续度", "default": 0.5, "min": 0.1, "max": 0.9 },
    { "name": "falloff", "type": "number", "label": "边缘衰减", "default": 0.5, "min": 0, "max": 1 }
  ],
  "outputs": [
    { "name": "heightMap", "type": "grid", "label": "高度图", "description": "0~1 浮点高度图，掩码外为 -1。" },
    { "name": "outputGrid", "type": "grid", "label": "预览网格", "description": "按高度粗分的海洋/海岸/陆地/山地预览。" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
