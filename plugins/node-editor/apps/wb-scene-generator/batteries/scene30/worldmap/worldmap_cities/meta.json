{
  "id": "worldmap_cities",
  "label": "世界地图城市",
  "description": "基于国家区域、陆地与高度图放置首都和主要城市，输出城市点位与城市覆盖层。",
  "description-en": "Places capitals and major cities from country regions, land, and height maps, outputting city points and an overlay grid.",
  "icon": "世界地图上多个城市点和首都星标。",
  "version": "1.0.0",
  "tags": ["worldmap", "city", "capital", "settlement", "poi"],
  "tag_labels": ["世界地图", "城市", "首都", "聚落", "兴趣点"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "landGrid", "type": "grid", "label": "陆地掩码" },
    { "name": "countryGrid", "type": "grid", "label": "国家网格" },
    { "name": "heightMap", "type": "grid", "label": "高度图" },
    { "name": "seed", "type": "number", "label": "随机种子", "default": 12345 },
    { "name": "cityCount", "type": "number", "label": "城市总数", "default": 56, "min": 0, "max": 240 },
    { "name": "minRegionArea", "type": "number", "label": "最小可建城区域", "default": 120, "min": 1, "max": 10000 }
  ],
  "outputs": [
    { "name": "cityGrid", "type": "grid", "label": "城市网格" },
    { "name": "cityPoints", "type": "array", "label": "城市点位" },
    { "name": "outputGrid", "type": "grid", "label": "城市网格" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
