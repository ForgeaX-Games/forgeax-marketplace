{
  "id": "worldmap_road_smooth",
  "label": "世界地图道路平滑",
  "description": "对世界地图道路和海底隧道进行补缝、闭运算或连续化平滑，使曲线路网更连贯完整。",
  "description-en": "Smooths worldmap roads and tunnels with gap closing, morphological closing, or continuity repair for more coherent road networks.",
  "icon": "世界地图上绿色道路被平滑成连续曲线，断裂处被补齐。",
  "version": "1.0.0",
  "tags": ["worldmap", "road", "smooth", "connect", "morphology"],
  "tag_labels": ["世界地图", "道路", "平滑", "连通", "形态学"],
  "projectTypes": ["scene", "both"],
  "inputs": [
    { "name": "roadGrid", "type": "grid", "label": "道路网格" },
    { "name": "tunnelGrid", "type": "grid", "label": "海底隧道网格" },
    { "name": "landGrid", "type": "grid", "label": "陆地掩码" },
    {
      "name": "algorithm",
      "type": "string",
      "label": "平滑算法",
      "default": "continuous",
      "options": ["close_gaps", "majority", "continuous"]
    },
    { "name": "iterations", "type": "number", "label": "迭代次数", "default": 1, "min": 1, "max": 4 },
    { "name": "gapRadius", "type": "number", "label": "断点补全半径", "default": 10, "min": 2, "max": 40 },
    { "name": "strokeRadius", "type": "number", "label": "道路笔刷半径", "default": 0, "min": 0, "max": 4 }
  ],
  "outputs": [
    { "name": "roadGrid", "type": "grid", "label": "平滑道路网格" },
    { "name": "tunnelGrid", "type": "grid", "label": "平滑隧道网格" },
    { "name": "outputGrid", "type": "grid", "label": "道路+隧道预览" },
    { "name": "outputNameList", "type": "array", "label": "名称清单" }
  ]
}
