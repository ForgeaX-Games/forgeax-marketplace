{
  "id": "pt2_construct",
  "label": "构造2D点",
  "name-en": "Pt2Construct",
  "description": "把两个数值组合成一个 point2d 端口值。",
  "description-en": "Compose two numbers into a point2d port value.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["point2d", "basic", "construct"],
  "tag_labels": ["二维点", "基础", "构造"],
  "inputs": [
    {
      "name": "x",
      "type": "number",
      "label": "x",
      "description": "X 分量",
      "description-en": "X component.",
      "default": 0
    },
    {
      "name": "y",
      "type": "number",
      "label": "y",
      "description": "Y 分量",
      "description-en": "Y component.",
      "default": 0
    }
  ],
  "outputs": [
    {
      "name": "point",
      "type": "point2d",
      "label": "point",
      "description": "组合而成的二维点",
      "description-en": "Composed 2D point."
    }
  ]
}
