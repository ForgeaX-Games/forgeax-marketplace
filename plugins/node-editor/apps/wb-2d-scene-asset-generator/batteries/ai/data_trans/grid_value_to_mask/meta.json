{
  "id": "grid_value_to_mask",
  "type": "ts",
  "label": "网格值转掩码",
  "category": "ai_tools",
  "description": "将网格中等于指定值的位置输出为 1，其余输出为 0，生成二值掩码。",
  "version": "1.0.0",
  "inputs": [
    {
      "name": "grid",
      "type": "grid",
      "label": "输入网格",
      "required": true
    },
    {
      "name": "targetValue",
      "type": "number",
      "label": "目标值",
      "default": 3,
      "description": "要提取的目标网格值"
    }
  ],
  "outputs": [
    {
      "name": "mask",
      "type": "grid",
      "label": "二值掩码"
    }
  ]
}
