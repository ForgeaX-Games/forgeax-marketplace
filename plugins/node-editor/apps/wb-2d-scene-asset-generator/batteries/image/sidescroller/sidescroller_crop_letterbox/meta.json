{
  "id": "sidescroller_crop_letterbox",
  "label": "横版裁黑边",
  "name-en": "CropLetterbox",
  "description": "检测顶部/底部低亮度黑边并裁掉，避免横版背景进入无缝和拼接阶段前带 letterbox。",
  "description-en": "Detect and crop low-brightness top/bottom letterbox bars before side-scroller background seamless processing.",
  "version": "1.0.0",
  "tags": ["image", "sidescroller", "crop", "letterbox"],
  "tag_labels": ["图像", "横版", "裁剪", "黑边"],
  "projectTypes": ["asset2d"],
  "inputs": [
    { "name": "image", "type": "image", "access": "item", "required": true, "label": "图像" },
    { "name": "threshold", "type": "number", "access": "item", "label": "黑边亮度阈值", "default": 15, "min": 0, "max": 255 }
  ],
  "outputs": [
    { "name": "image", "type": "image", "access": "item", "label": "裁剪后图像" },
    { "name": "width", "type": "number", "access": "item", "label": "宽度" },
    { "name": "height", "type": "number", "access": "item", "label": "高度" },
    { "name": "cropped", "type": "boolean", "access": "item", "label": "是否裁剪" },
    { "name": "error", "type": "string", "access": "item", "label": "错误信息" }
  ],
  "params": [
    { "name": "suffix", "type": "string", "default": "_crop", "label": "alias 后缀" }
  ],
  "alg_tag": ["横版背景", "黑边裁剪"]
}
