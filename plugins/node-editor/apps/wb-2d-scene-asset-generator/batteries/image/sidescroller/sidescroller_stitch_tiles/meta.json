{
  "id": "sidescroller_stitch_tiles",
  "label": "横版拼接",
  "name-en": "StitchSidescroller",
  "description": "把已处理的横版 tile 横向拼接为长背景，默认 3 段、无重叠，640x360 输入得到 1920x360 输出。",
  "description-en": "Stitch a processed side-scroller tile into a wide background, defaulting to 3 direct-abutment tiles.",
  "version": "1.0.0",
  "tags": ["image", "sidescroller", "stitch", "background"],
  "tag_labels": ["图像", "横版", "拼接", "背景"],
  "projectTypes": ["asset2d"],
  "inputs": [
    { "name": "image", "type": "image", "access": "item", "required": true, "label": "图像" },
    { "name": "tiles", "type": "number", "access": "item", "label": "拼接段数", "default": 3, "min": 1, "max": 20 },
    { "name": "overlap", "type": "number", "access": "item", "label": "重叠宽度", "default": 0, "min": 0, "max": 1024 }
  ],
  "outputs": [
    { "name": "image", "type": "image", "access": "item", "label": "拼接后图像" },
    { "name": "width", "type": "number", "access": "item", "label": "宽度" },
    { "name": "height", "type": "number", "access": "item", "label": "高度" },
    { "name": "error", "type": "string", "access": "item", "label": "错误信息" }
  ],
  "params": [
    { "name": "suffix", "type": "string", "default": "_x3", "label": "alias 后缀" }
  ],
  "alg_tag": ["横版背景", "三段拼接"]
}
