{
  "id": "g_rotate",
  "label": "旋转",
  "name-en": "GRotate",
  "description": "绕指定轴旋转 shape，角度单位为度。",
  "description-en": "Rotate a shape around an axis, with angle in degrees.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "csg", "transform", "cad"],
  "tag_labels": ["几何", "CSG", "变换", "CAD"],
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何" },
    { "name": "shape_id", "type": "string", "label": "Shape id", "default": "" },
    { "name": "angle_deg", "type": "number", "label": "角度", "default": 90 },
    { "name": "ax", "type": "number", "label": "轴 X", "default": 0 },
    { "name": "ay", "type": "number", "label": "轴 Y", "default": 0 },
    { "name": "az", "type": "number", "label": "轴 Z", "default": 1 },
    { "name": "ox", "type": "number", "label": "原点 X", "default": 0 },
    { "name": "oy", "type": "number", "label": "原点 Y", "default": 0 },
    { "name": "oz", "type": "number", "label": "原点 Z", "default": 0 },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "" }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何" },
    { "name": "id", "type": "string", "label": "id" }
  ],
  "projectTypes": ["asset3d"]
}
