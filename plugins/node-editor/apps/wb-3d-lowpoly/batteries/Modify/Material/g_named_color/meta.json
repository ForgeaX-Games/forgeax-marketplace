{
  "id": "g_named_color",
  "label": "命名颜色",
  "name-en": "GNamedColor",
  "description": "把预设颜色名（white / black / steel / brass / red / blue / glass 等）翻译成 r/g/b/a 四个数；下游接 g_material 即可。",
  "description-en": "Resolve a named color preset (white, black, steel, brass, red, blue, glass, etc.) to r/g/b/a numbers. Feed the four outputs into g_material.",
  "version": "1.0.0",
  "autoIterate": false,
  "tags": [
    "geometry",
    "material",
    "color",
    "preset"
  ],
  "tag_labels": [
    "几何",
    "材质",
    "颜色",
    "预设"
  ],
  "inputs": [
    {
      "name": "name",
      "type": "string",
      "label": "颜色名",
      "default": "gray",
      "description": "white/gray/black/silver/steel/brass/copper/gold/red/orange/yellow/green/blue/cyan/purple/pink/plastic/rubber/wood/glass",
      "description-en": "white/gray/black/silver/steel/brass/copper/gold/red/orange/yellow/green/blue/cyan/purple/pink/plastic/rubber/wood/glass."
    }
  ],
  "outputs": [
    {
      "name": "r",
      "type": "number",
      "label": "红 r",
      "description": "0-1",
      "description-en": "0-1."
    },
    {
      "name": "g",
      "type": "number",
      "label": "绿 g",
      "description": "0-1",
      "description-en": "0-1."
    },
    {
      "name": "b",
      "type": "number",
      "label": "蓝 b",
      "description": "0-1",
      "description-en": "0-1."
    },
    {
      "name": "a",
      "type": "number",
      "label": "不透明 a",
      "description": "0-1",
      "description-en": "0-1."
    },
    {
      "name": "name",
      "type": "string",
      "label": "颜色名",
      "description": "原样回传供 material 命名",
      "description-en": "Echo the resolved name."
    }
  ],
  "projectTypes": [
    "asset3d"
  ]
}
