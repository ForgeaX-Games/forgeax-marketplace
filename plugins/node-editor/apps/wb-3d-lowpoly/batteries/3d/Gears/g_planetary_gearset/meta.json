{
  "id": "g_planetary_gearset",
  "label": "行星齿轮组",
  "name-en": "GPlanetaryGearset",
  "description": "在 Geometry DSL 末尾追加 planetary_gearset(...) 一行（sun + n planets + ring 一体烘成 mesh）。当 prompt 提到 行星齿轮 / 行星齿轮组 / 行星减速器 / planetary gear / epicyclic gear 时使用。",
  "description-en": "Append `planetary_gearset(...)` — sun + N planets + ring, baked as one mesh. Use when the prompt mentions a planetary / epicyclic gear set or planetary reducer.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "gear", "planetary", "assembly", "cad"],
  "tag_labels": ["几何", "齿轮", "行星", "齿轮组", "CAD"],
  "principal": "geometry",
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何", "description": "上游 Geometry；缺省视为空", "description-en": "Upstream Geometry; empty when absent." },
    { "name": "module", "type": "number", "label": "模数 m", "default": 0.002, "description": "模数（米）", "description-en": "Module (meters)." },
    { "name": "sun_teeth_number", "type": "number", "label": "太阳齿数", "default": 12, "description": "太阳轮齿数（整数，>= 3）", "description-en": "Sun gear tooth count (integer, >= 3)." },
    { "name": "planet_teeth_number", "type": "number", "label": "行星齿数", "default": 18, "description": "行星轮齿数（整数，>= 3）", "description-en": "Planet gear tooth count (integer, >= 3)." },
    { "name": "width", "type": "number", "label": "齿宽", "default": 0.018, "description": "齿宽 / 厚度（米）", "description-en": "Face width / thickness (meters)." },
    { "name": "rim_width", "type": "number", "label": "外圈壁厚", "default": 0.005, "description": "内齿圈外壁厚（米）", "description-en": "Ring rim wall thickness (meters)." },
    { "name": "n_planets", "type": "number", "label": "行星数", "default": 3, "description": "行星轮数量（整数，>= 1）", "description-en": "Number of planets (integer, >= 1)." },
    { "name": "pressure_angle", "type": "number", "label": "压力角 (°)", "default": 0, "description": "0 = 用默认 20°", "description-en": "0 = use default 20°." },
    { "name": "helix_angle", "type": "number", "label": "螺旋角 (°)", "default": 0, "description": "0 = 直齿；非 0 = 斜齿行星组", "description-en": "0 = spur; non-zero = helical planetary set." },
    { "name": "clearance", "type": "number", "label": "顶隙", "default": 0, "description": "齿顶径向间隙", "description-en": "Tip radial clearance." },
    { "name": "backlash", "type": "number", "label": "侧隙", "default": 0, "description": "齿面侧隙", "description-en": "Tooth-flank backlash." },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "", "description": "自定义 id；空 = 自动 plan{n}", "description-en": "Custom id; empty = auto plan{n}." }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何", "description": "追加 planetary_gearset 行后的 Geometry", "description-en": "Geometry after appending the planetary gearset." },
    { "name": "id", "type": "string", "label": "id", "description": "本行 shape 的 id（供下游 g_part 的 shape_id 引用）", "description-en": "Id of the new shape (feed into a downstream g_part's shape_id)." }
  ],
  "projectTypes": ["asset3d"]
}
