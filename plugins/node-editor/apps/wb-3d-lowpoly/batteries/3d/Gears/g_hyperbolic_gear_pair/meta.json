{
  "id": "g_hyperbolic_gear_pair",
  "label": "双曲齿轮对",
  "name-en": "GHyperbolicGearPair",
  "description": "在 Geometry DSL 末尾追加 hyperbolic_gear_pair(...) 一行（两个双曲齿轮按 shaft_angle 一体烘）。当 prompt 提到 双曲齿轮副 / 准双曲齿轮副 / hyperbolic gear pair / hypoid pair 时使用。",
  "description-en": "Append `hyperbolic_gear_pair(...)` — two hyperbolic gears baked together at shaft_angle. Use when the prompt mentions a hyperbolic / hypoid gear pair.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "gear", "hyperbolic", "pair", "cad"],
  "tag_labels": ["几何", "齿轮", "双曲齿", "齿轮对", "CAD"],
  "principal": "geometry",
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何", "description": "上游 Geometry；缺省视为空", "description-en": "Upstream Geometry; empty when absent." },
    { "name": "module", "type": "number", "label": "模数 m", "default": 0.002, "description": "模数（米）", "description-en": "Module (meters)." },
    { "name": "gear1_teeth_number", "type": "number", "label": "齿轮 1 齿数", "default": 20, "description": "齿轮 1 齿数（整数，>= 3）", "description-en": "Gear 1 tooth count (integer, >= 3)." },
    { "name": "width", "type": "number", "label": "齿宽", "default": 0.01, "description": "齿宽 / 厚度（米）", "description-en": "Face width / thickness (meters)." },
    { "name": "shaft_angle", "type": "number", "label": "轴夹角 (°)", "default": 30, "description": "两轴夹角（度）", "description-en": "Crossed-shaft angle (degrees)." },
    { "name": "gear2_teeth_number", "type": "number", "label": "齿轮 2 齿数", "default": 0, "description": "0 = 与 gear1 相同", "description-en": "0 = same as gear 1." },
    { "name": "pressure_angle", "type": "number", "label": "压力角 (°)", "default": 0, "description": "0 = 用默认 20°", "description-en": "0 = use default 20°." },
    { "name": "clearance", "type": "number", "label": "顶隙", "default": 0, "description": "齿顶径向间隙", "description-en": "Tip radial clearance." },
    { "name": "backlash", "type": "number", "label": "侧隙", "default": 0, "description": "齿面侧隙", "description-en": "Tooth-flank backlash." },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "", "description": "自定义 id；空 = 自动 hyppr{n}", "description-en": "Custom id; empty = auto hyppr{n}." }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何", "description": "追加 hyperbolic_gear_pair 行后的 Geometry", "description-en": "Geometry after appending the hyperbolic gear pair." },
    { "name": "id", "type": "string", "label": "id", "description": "本行 shape 的 id（供下游 g_part 的 shape_id 引用）", "description-en": "Id of the new shape (feed into a downstream g_part's shape_id)." }
  ],
  "projectTypes": ["asset3d"]
}
