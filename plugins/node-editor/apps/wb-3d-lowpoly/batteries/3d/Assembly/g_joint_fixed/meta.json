{
  "id": "g_joint_fixed",
  "label": "固定连接",
  "name-en": "GJointFixed",
  "description": "把 parent / child 两个 part 用 fixed joint 刚性连接（URDF type=\"fixed\"）。何时用：零件之间不需要相对运动但必须连成一体。⚠️ parent/child 必须是已存在的 part（g_part 的 id），且所有 part 要连成单一根树，否则会被 URDF 丢弃。",
  "description-en": "Rigidly connect two parts with a fixed joint. Use when: parts must attach but not move relative to each other. WARNING: parent/child must be existing parts (g_part ids); every part must be joined into one rooted tree or it is dropped from the URDF.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": [
    "geometry",
    "joint",
    "fixed",
    "assembly",
    "urdf"
  ],
  "tag_labels": [
    "几何",
    "关节",
    "固定",
    "装配",
    "URDF"
  ],
  "inputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "required": true,
      "label": "几何",
      "description": "上游 Geometry",
      "description-en": "Upstream Geometry."
    },
    {
      "name": "parent_id",
      "type": "string",
      "required": true,
      "label": "父部件 id",
      "description": "父 part id（g_part 的 id 输出——是 PART id，不是 shape id）",
      "description-en": "Parent PART id — the `id` output of an upstream g_part (a part id, not a shape id)."
    },
    {
      "name": "child_id",
      "type": "string",
      "required": true,
      "label": "子部件 id",
      "description": "子 part id（g_part 的 id 输出）",
      "description-en": "Child PART id — the `id` output of an upstream g_part."
    },
    {
      "name": "ox",
      "type": "number",
      "label": "原点 X",
      "default": 0,
      "description": "joint 原点 X",
      "description-en": "Joint origin X."
    },
    {
      "name": "oy",
      "type": "number",
      "label": "原点 Y",
      "default": 0,
      "description": "joint 原点 Y",
      "description-en": "Joint origin Y."
    },
    {
      "name": "oz",
      "type": "number",
      "label": "原点 Z",
      "default": 0,
      "description": "joint 原点 Z",
      "description-en": "Joint origin Z."
    },
    {
      "name": "rr",
      "type": "number",
      "label": "翻滚 roll",
      "default": 0,
      "description": "roll 弧度",
      "description-en": "Roll radians."
    },
    {
      "name": "rp",
      "type": "number",
      "label": "俯仰 pitch",
      "default": 0,
      "description": "pitch 弧度",
      "description-en": "Pitch radians."
    },
    {
      "name": "ry",
      "type": "number",
      "label": "偏航 yaw",
      "default": 0,
      "description": "yaw 弧度",
      "description-en": "Yaw radians."
    },
    {
      "name": "id",
      "type": "string",
      "required": false,
      "label": "id",
      "default": "",
      "description": "自定义 id；空 = 自动 jfix{n}",
      "description-en": "Custom id; empty = auto jfix{n}."
    }
  ],
  "outputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "label": "几何",
      "description": "追加后 Geometry",
      "description-en": "Geometry after appending."
    },
    {
      "name": "id",
      "type": "string",
      "label": "id",
      "description": "本行 joint 的 id",
      "description-en": "Id of the new joint."
    }
  ],
  "projectTypes": [
    "asset3d"
  ]
}
