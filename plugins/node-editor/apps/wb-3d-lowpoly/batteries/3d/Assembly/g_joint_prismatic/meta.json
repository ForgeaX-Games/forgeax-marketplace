{
  "id": "g_joint_prismatic",
  "label": "平移关节",
  "name-en": "GJointPrismatic",
  "description": "平移关节：parent 与 child 之间沿 axis 平移，lower/upper 限位（米）。何时用：直线滑动（抽屉/滑轨/活塞/伸缩段）。⚠️ parent/child 必须是 g_part 的 id，且所有 part 要连成单一根树，否则会被 URDF 丢弃。",
  "description-en": "Prismatic joint with axis and lower/upper limits in meters. Use when: linear sliding (drawer/rail/piston/telescoping section). WARNING: parent/child must be g_part ids; every part must be joined into one rooted tree or it is dropped from the URDF.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": [
    "geometry",
    "joint",
    "prismatic",
    "urdf",
    "articulation"
  ],
  "tag_labels": [
    "几何",
    "关节",
    "平移",
    "URDF",
    "可动"
  ],
  "inputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "required": true,
      "label": "几何",
      "description": "上游 Geometry",
      "description-en": "Upstream Geometry."
    },
    {
      "name": "parent_id",
      "type": "string",
      "required": true,
      "label": "父部件 id",
      "description": "父 part id（g_part 的 id 输出——是 PART id，不是 shape id）",
      "description-en": "Parent PART id — the `id` output of an upstream g_part (a part id, not a shape id)."
    },
    {
      "name": "child_id",
      "type": "string",
      "required": true,
      "label": "子部件 id",
      "description": "子 part id（g_part 的 id 输出）",
      "description-en": "Child PART id — the `id` output of an upstream g_part."
    },
    {
      "name": "ax",
      "type": "number",
      "label": "轴 X",
      "default": 0,
      "description": "平移轴 X 分量",
      "description-en": "Translation axis X."
    },
    {
      "name": "ay",
      "type": "number",
      "label": "轴 Y",
      "default": 0,
      "description": "平移轴 Y 分量",
      "description-en": "Translation axis Y."
    },
    {
      "name": "az",
      "type": "number",
      "label": "轴 Z",
      "default": 1,
      "description": "平移轴 Z 分量（缺省沿 Z）",
      "description-en": "Translation axis Z (default)."
    },
    {
      "name": "lower",
      "type": "number",
      "label": "下限",
      "default": -0.5,
      "description": "位移下限（米）",
      "description-en": "Lower travel (m)."
    },
    {
      "name": "upper",
      "type": "number",
      "label": "上限",
      "default": 0.5,
      "description": "位移上限（米）",
      "description-en": "Upper travel (m)."
    },
    {
      "name": "ox",
      "type": "number",
      "label": "原点 X",
      "default": 0,
      "description": "joint 原点 X",
      "description-en": "Joint origin X."
    },
    {
      "name": "oy",
      "type": "number",
      "label": "原点 Y",
      "default": 0,
      "description": "joint 原点 Y",
      "description-en": "Joint origin Y."
    },
    {
      "name": "oz",
      "type": "number",
      "label": "原点 Z",
      "default": 0,
      "description": "joint 原点 Z",
      "description-en": "Joint origin Z."
    },
    {
      "name": "rr",
      "type": "number",
      "label": "翻滚 roll",
      "default": 0,
      "description": "roll 弧度",
      "description-en": "Roll radians."
    },
    {
      "name": "rp",
      "type": "number",
      "label": "俯仰 pitch",
      "default": 0,
      "description": "pitch 弧度",
      "description-en": "Pitch radians."
    },
    {
      "name": "ry",
      "type": "number",
      "label": "偏航 yaw",
      "default": 0,
      "description": "yaw 弧度",
      "description-en": "Yaw radians."
    },
    {
      "name": "effort",
      "type": "number",
      "label": "最大力",
      "default": 0,
      "description": "最大推/拉力；0 = 不写",
      "description-en": "Max effort; 0 = omit."
    },
    {
      "name": "velocity",
      "type": "number",
      "label": "最大速度",
      "default": 0,
      "description": "最大线速度；0 = 不写",
      "description-en": "Max velocity; 0 = omit."
    },
    {
      "name": "id",
      "type": "string",
      "required": false,
      "label": "id",
      "default": "",
      "description": "自定义 id；空 = 自动 jpri{n}",
      "description-en": "Custom id; empty = auto jpri{n}."
    }
  ],
  "outputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "label": "几何",
      "description": "追加后 Geometry",
      "description-en": "Geometry after appending."
    },
    {
      "name": "id",
      "type": "string",
      "label": "id",
      "description": "本行 joint 的 id",
      "description-en": "Id of the new joint."
    }
  ],
  "projectTypes": [
    "asset3d"
  ]
}
