{
  "id": "g_joint_floating",
  "label": "自由关节",
  "name-en": "GJointFloating",
  "description": "自由关节（6-DoF）：child 相对 parent 不受约束。常用于浮动基座或调试。何时用：浮动基座/调试（一般装配优先用 fixed/revolute/prismatic）。⚠️ parent/child 必须是 g_part 的 id，且所有 part 要连成单一根树，否则会被 URDF 丢弃。",
  "description-en": "Floating (6-DoF) joint with no axis/limit constraints. Use when: a floating base or debugging (prefer fixed/revolute/prismatic for normal assemblies). WARNING: parent/child must be g_part ids; every part must be joined into one rooted tree or it is dropped from the URDF.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": [
    "geometry",
    "joint",
    "floating",
    "urdf",
    "articulation"
  ],
  "tag_labels": [
    "几何",
    "关节",
    "自由",
    "URDF",
    "可动"
  ],
  "inputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "required": true,
      "label": "几何",
      "description": "上游 Geometry",
      "description-en": "Upstream Geometry."
    },
    {
      "name": "parent_id",
      "type": "string",
      "required": true,
      "label": "父部件 id",
      "description": "父 part id（g_part 的 id 输出——是 PART id，不是 shape id）",
      "description-en": "Parent PART id — the `id` output of an upstream g_part (a part id, not a shape id)."
    },
    {
      "name": "child_id",
      "type": "string",
      "required": true,
      "label": "子部件 id",
      "description": "子 part id（g_part 的 id 输出）",
      "description-en": "Child PART id — the `id` output of an upstream g_part."
    },
    {
      "name": "ox",
      "type": "number",
      "label": "原点 X",
      "default": 0,
      "description": "joint 原点 X",
      "description-en": "Joint origin X."
    },
    {
      "name": "oy",
      "type": "number",
      "label": "原点 Y",
      "default": 0,
      "description": "joint 原点 Y",
      "description-en": "Joint origin Y."
    },
    {
      "name": "oz",
      "type": "number",
      "label": "原点 Z",
      "default": 0,
      "description": "joint 原点 Z",
      "description-en": "Joint origin Z."
    },
    {
      "name": "rr",
      "type": "number",
      "label": "翻滚 roll",
      "default": 0,
      "description": "roll 弧度",
      "description-en": "Roll radians."
    },
    {
      "name": "rp",
      "type": "number",
      "label": "俯仰 pitch",
      "default": 0,
      "description": "pitch 弧度",
      "description-en": "Pitch radians."
    },
    {
      "name": "ry",
      "type": "number",
      "label": "偏航 yaw",
      "default": 0,
      "description": "yaw 弧度",
      "description-en": "Yaw radians."
    },
    {
      "name": "id",
      "type": "string",
      "required": false,
      "label": "id",
      "default": "",
      "description": "自定义 id；空 = 自动 jflo{n}",
      "description-en": "Custom id; empty = auto jflo{n}."
    }
  ],
  "outputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "label": "几何",
      "description": "追加后 Geometry",
      "description-en": "Geometry after appending."
    },
    {
      "name": "id",
      "type": "string",
      "label": "id",
      "description": "本行 joint 的 id",
      "description-en": "Id of the new joint."
    }
  ],
  "projectTypes": [
    "asset3d"
  ]
}
