{
  "id": "g_scale",
  "label": "等比缩放",
  "name-en": "GScale",
  "description": "对 shape 做等比缩放。",
  "description-en": "Uniformly scale a shape.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "csg", "transform", "cad"],
  "tag_labels": ["几何", "CSG", "变换", "CAD"],
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何" },
    { "name": "shape_id", "type": "string", "label": "Shape id", "default": "" },
    { "name": "factor", "type": "number", "label": "缩放因子", "default": 1 },
    { "name": "cx", "type": "number", "label": "中心 X", "default": 0 },
    { "name": "cy", "type": "number", "label": "中心 Y", "default": 0 },
    { "name": "cz", "type": "number", "label": "中心 Z", "default": 0 },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "" }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何" },
    { "name": "id", "type": "string", "label": "id" }
  ],
  "projectTypes": ["asset3d"]
}
