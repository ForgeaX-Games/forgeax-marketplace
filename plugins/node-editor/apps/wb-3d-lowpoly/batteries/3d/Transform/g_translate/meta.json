{
  "id": "g_translate",
  "label": "平移",
  "name-en": "GTranslate",
  "description": "平移一个 shape，追加 translate(shape, offset) 到 Geometry DSL。",
  "description-en": "Translate a shape by an offset vector.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "csg", "transform", "cad"],
  "tag_labels": ["几何", "CSG", "变换", "CAD"],
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何" },
    { "name": "shape_id", "type": "string", "label": "Shape id", "default": "" },
    { "name": "x", "type": "number", "label": "X", "default": 0 },
    { "name": "y", "type": "number", "label": "Y", "default": 0 },
    { "name": "z", "type": "number", "label": "Z", "default": 0 },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "" }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何" },
    { "name": "id", "type": "string", "label": "id" }
  ],
  "projectTypes": ["asset3d"]
}
