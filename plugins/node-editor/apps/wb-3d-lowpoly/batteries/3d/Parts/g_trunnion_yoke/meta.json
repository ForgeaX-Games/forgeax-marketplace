{
  "id": "g_trunnion_yoke",
  "label": "耳轴支座",
  "name-en": "GTrunnionYoke",
  "description": "在 Geometry DSL 末尾追加 trunnion_yoke(...) 一行。两颊托耳轴的 U 形座。当 prompt 提到 耳轴支座 / 轴承座 / U 形托架 / trunnion / yoke 时使用。",
  "description-en": "Append `trunnion_yoke(...)` — two cheeks supporting a trunnion. Use when the prompt mentions a trunnion mount / yoke / U-shaped bearing support.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "part", "yoke", "cad"],
  "tag_labels": ["几何", "语义零件", "支座", "CAD"],
  "principal": "geometry",
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何", "description": "上游 Geometry；缺省视为空", "description-en": "Upstream Geometry; empty when absent." },
    { "name": "w", "type": "number", "label": "外形宽 w", "default": 0.08, "description": "整体 X 尺寸", "description-en": "Overall X size." },
    { "name": "d", "type": "number", "label": "外形深 d", "default": 0.04, "description": "整体 Y 尺寸", "description-en": "Overall Y size." },
    { "name": "h", "type": "number", "label": "外形高 h", "default": 0.06, "description": "整体 Z 尺寸", "description-en": "Overall Z size." },
    { "name": "span_width", "type": "number", "label": "两颊间距", "default": 0.04, "description": "两托颊净间距", "description-en": "Clear span between the two cheeks." },
    { "name": "trunnion_diameter", "type": "number", "label": "耳轴径", "default": 0.012, "description": "耳轴/轴孔直径", "description-en": "Trunnion (bore) diameter." },
    { "name": "trunnion_center_z", "type": "number", "label": "轴心高", "default": 0.045, "description": "轴心距底面高度", "description-en": "Trunnion-center height above base." },
    { "name": "base_thickness", "type": "number", "label": "底厚", "default": 0.012, "description": "底座厚度", "description-en": "Base plate thickness." },
    { "name": "corner_radius", "type": "number", "label": "外圆角", "default": 0, "description": "0 = 不倒角", "description-en": "0 = no fillet." },
    { "name": "center", "type": "bool", "required": false, "label": "居中", "default": true, "description": "true = 关于原点居中", "description-en": "true = center about the origin." },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "", "description": "自定义 id；空 = 自动 yoke{n}", "description-en": "Custom id; empty = auto yoke{n}." }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何", "description": "追加 trunnion_yoke 行后的 Geometry", "description-en": "Geometry after appending the yoke." },
    { "name": "id", "type": "string", "label": "id", "description": "本行 shape 的 id（供下游 g_part 的 shape_id 引用）", "description-en": "Id of the new shape (feed into a downstream g_part's shape_id)." }
  ],
  "projectTypes": ["asset3d"]
}
