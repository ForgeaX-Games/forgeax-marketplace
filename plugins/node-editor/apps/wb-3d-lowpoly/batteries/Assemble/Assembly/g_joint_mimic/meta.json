{
  "id": "g_joint_mimic",
  "label": "联动关节",
  "name-en": "GJointMimic",
  "description": "创建一个带 URDF mimic 的从动关节，用 source_joint_id 的运动值乘 multiplier 再加 offset 驱动。何时用：联动机构（齿轮联动、夹爪同步、连杆跟随）。⚠️ parent/child 必须是 g_part 的 id，source_joint_id 必须是已存在 joint 的 id，且所有 part 要连成单一根树，否则会被 URDF 丢弃。",
  "description-en": "Create a URDF mimic joint driven by source_joint_id * multiplier + offset. Use when: linked motion (geared coupling, synchronized gripper, follower linkage). WARNING: parent/child must be g_part ids and source_joint_id must be an existing joint id; every part must be joined into one rooted tree or it is dropped from the URDF.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": [
    "geometry",
    "joint",
    "mimic",
    "assembly",
    "urdf"
  ],
  "tag_labels": [
    "几何",
    "关节",
    "联动",
    "装配",
    "URDF"
  ],
  "inputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "required": true,
      "label": "几何",
      "description": "上游 Geometry",
      "description-en": "Upstream Geometry."
    },
    {
      "name": "parent_id",
      "type": "string",
      "required": true,
      "label": "父部件 id",
      "description": "父 part id（g_part 的 id 输出——是 PART id，不是 shape id）",
      "description-en": "Parent PART id — the `id` output of an upstream g_part (a part id, not a shape id)."
    },
    {
      "name": "child_id",
      "type": "string",
      "required": true,
      "label": "子部件 id",
      "description": "子 part id（g_part 的 id 输出）",
      "description-en": "Child PART id — the `id` output of an upstream g_part."
    },
    {
      "name": "source_joint_id",
      "type": "string",
      "required": true,
      "label": "源关节 id",
      "description": "被联动跟随的 joint id",
      "description-en": "Source joint id."
    },
    {
      "name": "type",
      "type": "string",
      "label": "关节类型",
      "default": "revolute",
      "description": "revolute / continuous / prismatic",
      "description-en": "revolute / continuous / prismatic."
    },
    {
      "name": "multiplier",
      "type": "number",
      "label": "倍率",
      "default": 1,
      "description": "mimic multiplier",
      "description-en": "Mimic multiplier."
    },
    {
      "name": "offset",
      "type": "number",
      "label": "偏移",
      "default": 0,
      "description": "mimic offset",
      "description-en": "Mimic offset."
    },
    {
      "name": "ax",
      "type": "number",
      "label": "轴 X",
      "default": 0,
      "description": "关节轴 X",
      "description-en": "Joint axis X."
    },
    {
      "name": "ay",
      "type": "number",
      "label": "轴 Y",
      "default": 0,
      "description": "关节轴 Y",
      "description-en": "Joint axis Y."
    },
    {
      "name": "az",
      "type": "number",
      "label": "轴 Z",
      "default": 1,
      "description": "关节轴 Z",
      "description-en": "Joint axis Z."
    },
    {
      "name": "lower",
      "type": "number",
      "label": "下限",
      "default": -3.14159,
      "description": "revolute/prismatic 下限",
      "description-en": "Lower limit."
    },
    {
      "name": "upper",
      "type": "number",
      "label": "上限",
      "default": 3.14159,
      "description": "revolute/prismatic 上限",
      "description-en": "Upper limit."
    },
    {
      "name": "ox",
      "type": "number",
      "label": "原点 X",
      "default": 0,
      "description": "joint 原点 X",
      "description-en": "Joint origin X."
    },
    {
      "name": "oy",
      "type": "number",
      "label": "原点 Y",
      "default": 0,
      "description": "joint 原点 Y",
      "description-en": "Joint origin Y."
    },
    {
      "name": "oz",
      "type": "number",
      "label": "原点 Z",
      "default": 0,
      "description": "joint 原点 Z",
      "description-en": "Joint origin Z."
    },
    {
      "name": "rr",
      "type": "number",
      "label": "roll",
      "default": 0,
      "description": "roll 弧度",
      "description-en": "Roll radians."
    },
    {
      "name": "rp",
      "type": "number",
      "label": "pitch",
      "default": 0,
      "description": "pitch 弧度",
      "description-en": "Pitch radians."
    },
    {
      "name": "ry",
      "type": "number",
      "label": "yaw",
      "default": 0,
      "description": "yaw 弧度",
      "description-en": "Yaw radians."
    },
    {
      "name": "effort",
      "type": "number",
      "label": "最大力/力矩",
      "default": 0,
      "description": "0 = 不写",
      "description-en": "0 = omit."
    },
    {
      "name": "velocity",
      "type": "number",
      "label": "最大速度",
      "default": 0,
      "description": "0 = 不写",
      "description-en": "0 = omit."
    },
    {
      "name": "id",
      "type": "string",
      "label": "id",
      "default": "",
      "description": "自定义 id；空 = 自动 jmim{n}",
      "description-en": "Custom id; empty = auto jmim{n}."
    }
  ],
  "outputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "label": "几何",
      "description": "追加后 Geometry",
      "description-en": "Geometry after appending."
    },
    {
      "name": "id",
      "type": "string",
      "label": "id",
      "description": "本行 joint 的 id",
      "description-en": "Id of the new joint."
    },
    {
      "name": "error",
      "type": "string",
      "label": "错误",
      "description": "非致命错误信息（校验失败时返回，几何原样透传）",
      "description-en": "Non-fatal error string (returned on validation failure; geometry passes through unchanged)."
    }
  ],
  "projectTypes": [
    "asset3d"
  ]
}
