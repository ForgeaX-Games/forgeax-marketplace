{
  "id": "g_joint_revolute",
  "label": "旋转关节",
  "name-en": "GJointRevolute",
  "description": "旋转关节：parent 与 child 之间绕 axis 旋转,受 lower/upper 限位（弧度）。何时用：有限角度的铰接（门/盖/摆臂/旋钮）。⚠️ parent/child 必须是 g_part 的 id，且所有 part 要连成单一根树，否则会被 URDF 丢弃。",
  "description-en": "Revolute joint with axis and lower/upper limits in radians. Use when: a limited-angle hinge (door/lid/swing arm/dial). WARNING: parent/child must be g_part ids; every part must be joined into one rooted tree or it is dropped from the URDF.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": [
    "geometry",
    "joint",
    "revolute",
    "urdf",
    "articulation"
  ],
  "tag_labels": [
    "几何",
    "关节",
    "旋转",
    "URDF",
    "可动"
  ],
  "inputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "required": true,
      "label": "几何",
      "description": "上游 Geometry",
      "description-en": "Upstream Geometry."
    },
    {
      "name": "parent_id",
      "type": "string",
      "required": true,
      "label": "父部件 id",
      "description": "父 part id（g_part 的 id 输出——是 PART id，不是 shape id）",
      "description-en": "Parent PART id — the `id` output of an upstream g_part (a part id, not a shape id)."
    },
    {
      "name": "child_id",
      "type": "string",
      "required": true,
      "label": "子部件 id",
      "description": "子 part id（g_part 的 id 输出）",
      "description-en": "Child PART id — the `id` output of an upstream g_part."
    },
    {
      "name": "ax",
      "type": "number",
      "label": "轴 X",
      "default": 0,
      "description": "旋转轴 X 分量",
      "description-en": "Rotation axis X."
    },
    {
      "name": "ay",
      "type": "number",
      "label": "轴 Y",
      "default": 0,
      "description": "旋转轴 Y 分量",
      "description-en": "Rotation axis Y."
    },
    {
      "name": "az",
      "type": "number",
      "label": "轴 Z",
      "default": 1,
      "description": "旋转轴 Z 分量（缺省绕 Z）",
      "description-en": "Rotation axis Z (default)."
    },
    {
      "name": "lower",
      "type": "number",
      "label": "下限",
      "default": -3.14159,
      "description": "角度下限（弧度）",
      "description-en": "Lower angle (rad)."
    },
    {
      "name": "upper",
      "type": "number",
      "label": "上限",
      "default": 3.14159,
      "description": "角度上限（弧度）",
      "description-en": "Upper angle (rad)."
    },
    {
      "name": "ox",
      "type": "number",
      "label": "原点 X",
      "default": 0,
      "description": "joint 原点 X",
      "description-en": "Joint origin X."
    },
    {
      "name": "oy",
      "type": "number",
      "label": "原点 Y",
      "default": 0,
      "description": "joint 原点 Y",
      "description-en": "Joint origin Y."
    },
    {
      "name": "oz",
      "type": "number",
      "label": "原点 Z",
      "default": 0,
      "description": "joint 原点 Z",
      "description-en": "Joint origin Z."
    },
    {
      "name": "rr",
      "type": "number",
      "label": "翻滚 roll",
      "default": 0,
      "description": "roll 弧度",
      "description-en": "Roll radians."
    },
    {
      "name": "rp",
      "type": "number",
      "label": "俯仰 pitch",
      "default": 0,
      "description": "pitch 弧度",
      "description-en": "Pitch radians."
    },
    {
      "name": "ry",
      "type": "number",
      "label": "偏航 yaw",
      "default": 0,
      "description": "yaw 弧度",
      "description-en": "Yaw radians."
    },
    {
      "name": "effort",
      "type": "number",
      "label": "最大力矩",
      "default": 0,
      "description": "最大力矩；0 = 不写",
      "description-en": "Max effort; 0 = omit."
    },
    {
      "name": "velocity",
      "type": "number",
      "label": "最大角速度",
      "default": 0,
      "description": "最大角速度；0 = 不写",
      "description-en": "Max velocity; 0 = omit."
    },
    {
      "name": "id",
      "type": "string",
      "required": false,
      "label": "id",
      "default": "",
      "description": "自定义 id；空 = 自动 jrev{n}",
      "description-en": "Custom id; empty = auto jrev{n}."
    }
  ],
  "outputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "label": "几何",
      "description": "追加后 Geometry",
      "description-en": "Geometry after appending."
    },
    {
      "name": "id",
      "type": "string",
      "label": "id",
      "description": "本行 joint 的 id",
      "description-en": "Id of the new joint."
    },
    {
      "name": "error",
      "type": "string",
      "label": "错误",
      "description": "非致命错误信息（校验失败时返回，几何原样透传）",
      "description-en": "Non-fatal error string (returned on validation failure; geometry passes through unchanged)."
    }
  ],
  "projectTypes": [
    "asset3d"
  ]
}
