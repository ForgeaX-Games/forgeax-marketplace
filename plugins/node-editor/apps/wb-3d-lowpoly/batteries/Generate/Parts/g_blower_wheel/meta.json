{
  "id": "g_blower_wheel",
  "label": "离心鼓风叶轮",
  "name-en": "GBlowerWheel",
  "description": "在 Geometry DSL 末尾追加 blower_wheel(...) 一行（多叶片离心鼓风轮）。当 prompt 提到 鼓风机 / 离心风轮 / 多翼叶轮 / 蜗壳叶轮 / blower / squirrel cage / centrifugal impeller 时使用。",
  "description-en": "Append `blower_wheel(...)` — centrifugal squirrel-cage wheel. Use when the prompt mentions a blower / squirrel-cage fan / centrifugal impeller / multi-vane wheel.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "part", "blower", "fan", "cad"],
  "tag_labels": ["几何", "语义零件", "鼓风", "风扇", "CAD"],
  "principal": "geometry",
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何", "description": "上游 Geometry；缺省视为空", "description-en": "Upstream Geometry; empty when absent." },
    { "name": "outer_radius", "type": "number", "label": "外径 R", "default": 0.05, "description": "叶轮外半径（米）", "description-en": "Wheel outer radius (meters)." },
    { "name": "inner_radius", "type": "number", "label": "内径 r", "default": 0.035, "description": "叶片内半径", "description-en": "Blade inner radius." },
    { "name": "width", "type": "number", "label": "宽 W", "default": 0.04, "description": "叶轮轴向宽度", "description-en": "Axial width of the wheel." },
    { "name": "blade_count", "type": "number", "label": "叶片数", "default": 24, "description": "叶片数量", "description-en": "Number of blades." },
    { "name": "blade_thickness", "type": "number", "label": "叶片厚", "default": 0.0015, "description": "单叶片厚度", "description-en": "Blade thickness." },
    { "name": "blade_sweep_deg", "type": "number", "label": "叶片掠角 (°)", "default": 0, "description": "叶片掠角（度）；0 = 默认 35°", "description-en": "Blade sweep angle (degrees); 0 = default 35°." },
    { "name": "backplate", "type": "bool", "required": false, "label": "后盘", "default": true, "description": "true = 含后盘", "description-en": "true = include the back plate." },
    { "name": "shroud", "type": "bool", "required": false, "label": "前罩", "default": false, "description": "true = 含前罩环", "description-en": "true = include the front shroud ring." },
    { "name": "center", "type": "bool", "required": false, "label": "居中", "default": true, "description": "true = 关于原点居中", "description-en": "true = center about the origin." },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "", "description": "自定义 id；空 = 自动 blower{n}", "description-en": "Custom id; empty = auto blower{n}." }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何", "description": "追加 blower_wheel 行后的 Geometry", "description-en": "Geometry after appending the blower wheel." },
    { "name": "id", "type": "string", "label": "id", "description": "本行 shape 的 id（供下游 g_part 的 shape_id 引用）", "description-en": "Id of the new shape (feed into a downstream g_part's shape_id)." }
  ],
  "projectTypes": ["asset3d"]
}
