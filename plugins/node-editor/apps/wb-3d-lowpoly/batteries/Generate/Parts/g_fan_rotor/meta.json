{
  "id": "g_fan_rotor",
  "label": "轴流风扇",
  "name-en": "GFanRotor",
  "description": "在 Geometry DSL 末尾追加 fan_rotor(...) 一行（轴流式扇叶转子）。当 prompt 提到 风扇 / 轴流风扇 / 螺旋桨 / 叶轮 / fan / propeller / impeller 时使用；转动时用 g_joint_continuous。",
  "description-en": "Append `fan_rotor(...)` — axial fan rotor with hub and blades. Use when the prompt mentions a fan / axial fan / propeller / impeller; spin it with g_joint_continuous.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "part", "fan", "rotor", "cad"],
  "tag_labels": ["几何", "语义零件", "风扇", "转子", "CAD"],
  "principal": "geometry",
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何", "description": "上游 Geometry；缺省视为空", "description-en": "Upstream Geometry; empty when absent." },
    { "name": "outer_radius", "type": "number", "label": "外径 R", "default": 0.04, "description": "叶尖外半径（米）", "description-en": "Blade-tip outer radius (meters)." },
    { "name": "hub_radius", "type": "number", "label": "轮毂半径", "default": 0.01, "description": "中心轮毂半径", "description-en": "Central hub radius." },
    { "name": "blade_count", "type": "number", "label": "叶片数", "default": 5, "description": "扇叶数量", "description-en": "Number of blades." },
    { "name": "thickness", "type": "number", "label": "整体厚", "default": 0.012, "description": "转子整体厚度", "description-en": "Overall rotor thickness." },
    { "name": "blade_pitch_deg", "type": "number", "label": "叶片螺距角 (°)", "default": 0, "description": "叶片螺距角（度）；0 = 默认 28°", "description-en": "Blade pitch angle (degrees); 0 = default 28°." },
    { "name": "blade_sweep_deg", "type": "number", "label": "叶片掠角 (°)", "default": 0, "description": "叶片掠角（度）；0 = 默认 20°", "description-en": "Blade sweep angle (degrees); 0 = default 20°." },
    { "name": "blade_root_chord", "type": "number", "label": "叶根弦长", "default": 0, "description": "叶根弦长；0 = 默认", "description-en": "Blade root chord; 0 = default." },
    { "name": "blade_tip_chord", "type": "number", "label": "叶尖弦长", "default": 0, "description": "叶尖弦长；0 = 默认", "description-en": "Blade tip chord; 0 = default." },
    { "name": "center", "type": "bool", "required": false, "label": "居中", "default": true, "description": "true = 关于原点居中", "description-en": "true = center about the origin." },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "", "description": "自定义 id；空 = 自动 fan{n}", "description-en": "Custom id; empty = auto fan{n}." }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何", "description": "追加 fan_rotor 行后的 Geometry", "description-en": "Geometry after appending the fan rotor." },
    { "name": "id", "type": "string", "label": "id", "description": "本行 shape 的 id（供下游 g_part 的 shape_id 引用）", "description-en": "Id of the new shape (feed into a downstream g_part's shape_id)." }
  ],
  "projectTypes": ["asset3d"]
}
