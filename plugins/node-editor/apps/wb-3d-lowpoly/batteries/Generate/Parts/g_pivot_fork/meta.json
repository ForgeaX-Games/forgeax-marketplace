{
  "id": "g_pivot_fork",
  "label": "枢轴叉",
  "name-en": "GPivotFork",
  "description": "在 Geometry DSL 末尾追加 pivot_fork(...) 一行。前开式叉，后桥连接两颊。当 prompt 提到 枢轴叉 / 叉臂 / 万向叉 / fork / yoke fork 时使用。",
  "description-en": "Append `pivot_fork(...)` — front-open fork with rear bridge. Use when the prompt mentions a pivot fork / fork arm / yoke fork.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "part", "fork", "cad"],
  "tag_labels": ["几何", "语义零件", "叉", "CAD"],
  "principal": "geometry",
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何", "description": "上游 Geometry；缺省视为空", "description-en": "Upstream Geometry; empty when absent." },
    { "name": "w", "type": "number", "label": "外形宽 w", "default": 0.06, "description": "整体 X 尺寸", "description-en": "Overall X size." },
    { "name": "d", "type": "number", "label": "外形深 d", "default": 0.04, "description": "整体 Y 尺寸", "description-en": "Overall Y size." },
    { "name": "h", "type": "number", "label": "外形高 h", "default": 0.05, "description": "整体 Z 尺寸", "description-en": "Overall Z size." },
    { "name": "gap_width", "type": "number", "label": "叉间距", "default": 0.02, "description": "两叉颊净间距", "description-en": "Clear gap between the two prongs." },
    { "name": "bore_diameter", "type": "number", "label": "孔径", "default": 0.008, "description": "横向通孔直径", "description-en": "Cross bore diameter." },
    { "name": "bore_center_z", "type": "number", "label": "孔心高", "default": 0.035, "description": "孔心距底面高度", "description-en": "Bore-center height above base." },
    { "name": "bridge_thickness", "type": "number", "label": "后桥厚", "default": 0.008, "description": "沿 Y 的后桥厚度", "description-en": "Rear bridge thickness along Y." },
    { "name": "corner_radius", "type": "number", "label": "外圆角", "default": 0, "description": "0 = 不倒角", "description-en": "0 = no fillet." },
    { "name": "center", "type": "bool", "required": false, "label": "居中", "default": true, "description": "true = 关于原点居中", "description-en": "true = center about the origin." },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "", "description": "自定义 id；空 = 自动 fork{n}", "description-en": "Custom id; empty = auto fork{n}." }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何", "description": "追加 pivot_fork 行后的 Geometry", "description-en": "Geometry after appending the fork." },
    { "name": "id", "type": "string", "label": "id", "description": "本行 shape 的 id（供下游 g_part 的 shape_id 引用）", "description-en": "Id of the new shape (feed into a downstream g_part's shape_id)." }
  ],
  "projectTypes": ["asset3d"]
}
