{
  "id": "g_slot_panel",
  "label": "槽孔板",
  "name-en": "GSlotPanel",
  "description": "在 Geometry DSL 末尾追加 slot_panel(...) 一行（圆头槽孔阵列板）。当 prompt 提到 槽孔板 / 长条孔 / 散热条缝 / 百叶缝 / slotted panel / slots 时使用。",
  "description-en": "Append `slot_panel(...)` — rounded-end slot array panel. Use when the prompt mentions slotted panel, slots, slot vents, or louvered slits.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "part", "panel", "slot", "cad"],
  "tag_labels": ["几何", "语义零件", "板", "槽", "CAD"],
  "principal": "geometry",
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何", "description": "上游 Geometry；缺省视为空", "description-en": "Upstream Geometry; empty when absent." },
    { "name": "panel_w", "type": "number", "label": "板宽", "default": 0.12, "description": "板宽（米）", "description-en": "Panel width (meters)." },
    { "name": "panel_h", "type": "number", "label": "板高", "default": 0.08, "description": "板高（米）", "description-en": "Panel height (meters)." },
    { "name": "thickness", "type": "number", "label": "板厚", "default": 0.003, "description": "板厚（米）", "description-en": "Panel thickness (meters)." },
    { "name": "slot_w", "type": "number", "label": "槽长", "default": 0.012, "description": "单槽长度", "description-en": "Slot length." },
    { "name": "slot_h", "type": "number", "label": "槽宽", "default": 0.003, "description": "单槽宽度（圆头）", "description-en": "Slot width (rounded ends)." },
    { "name": "pitch_x", "type": "number", "label": "X 节距", "default": 0.018, "description": "X 方向槽间距", "description-en": "Slot pitch along X." },
    { "name": "pitch_y", "type": "number", "label": "Y 节距", "default": 0.008, "description": "Y 方向槽间距", "description-en": "Slot pitch along Y." },
    { "name": "frame", "type": "number", "label": "外框宽", "default": 0.008, "description": "无孔外框宽度", "description-en": "Solid frame width around the slots." },
    { "name": "corner_radius", "type": "number", "label": "板角圆角", "default": 0, "description": "板角圆角半径", "description-en": "Panel corner radius." },
    { "name": "slot_angle_deg", "type": "number", "label": "槽倾角 (°)", "default": 0, "description": "槽倾斜角（度）", "description-en": "Slot tilt angle (degrees)." },
    { "name": "stagger", "type": "bool", "required": false, "label": "交错排布", "default": false, "description": "true = 行间交错排槽", "description-en": "true = stagger alternate rows." },
    { "name": "center", "type": "bool", "required": false, "label": "居中", "default": true, "description": "true = 关于原点居中", "description-en": "true = center about the origin." },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "", "description": "自定义 id；空 = 自动 slot{n}", "description-en": "Custom id; empty = auto slot{n}." }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何", "description": "追加 slot_panel 行后的 Geometry", "description-en": "Geometry after appending the slot panel." },
    { "name": "id", "type": "string", "label": "id", "description": "本行 shape 的 id（供下游 g_part 的 shape_id 引用）", "description-en": "Id of the new shape (feed into a downstream g_part's shape_id)." }
  ],
  "projectTypes": ["asset3d"]
}
