    { "name": "major_radius", "type": "number", "label": "主半径", "default": 0.5 },
    { "name": "minor_radius", "type": "number", "label": "管半径", "default": 0.1 },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "" }
