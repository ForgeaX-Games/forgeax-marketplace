{
  "id": "g_sphere",
  "label": "球体",
  "name-en": "GSphere",
  "description": "在 Geometry DSL 末尾追加 sphere(radius) 一行。",
  "description-en": "Append a `sphere(radius)` line.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": [
    "geometry",
    "primitive",
    "sphere",
    "cad"
  ],
  "tag_labels": [
    "几何",
    "基础形状",
    "球体",
    "CAD"
  ],
  "inputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "required": false,
      "label": "几何",
      "description": "上游 Geometry",
      "description-en": "Upstream Geometry."
    },
    {
      "name": "radius",
      "type": "number",
      "label": "半径",
      "default": 0.5,
      "description": "半径",
      "description-en": "Radius."
    },
    {
      "name": "id",
      "type": "string",
      "required": false,
      "label": "id",
      "default": "",
      "description": "自定义 id；空 = 自动 sph{n}",
      "description-en": "Custom id; empty = auto sph{n}."
    }
  ],
  "outputs": [
    {
      "name": "geometry",
      "type": "geometry",
      "label": "几何",
      "description": "追加后 Geometry",
      "description-en": "Geometry after appending."
    },
    {
      "name": "id",
      "type": "string",
      "label": "id",
      "description": "本行 sphere 的 id",
      "description-en": "Id of the sphere line."
    }
  ],
  "projectTypes": [
    "asset3d"
  ]
}
