{
  "id": "g_column",
  "label": "柱子",
  "name-en": "GColumn",
  "description": "追加 column(...)：圆/方立柱柱身 + 可选柱础(base)、柱头(capital)（height / radius / shape）。当 prompt 提到 柱子 / 立柱 / 柱 / 廊柱 / 罗马柱 / column / pillar / post 时使用。",
  "description-en": "Append `column(...)` — a round/square pillar shaft with optional base and capital. Use for column, pillar, post.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "architecture", "column", "cad"],
  "tag_labels": ["几何", "建筑", "柱子", "CAD"],
  "principal": "geometry",
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何", "description": "上游 Geometry；缺省视为空", "description-en": "Upstream Geometry; empty when absent." },
    { "name": "height", "type": "number", "label": "总高", "default": 3, "description": "柱总高（Z，米）", "description-en": "Total height along Z (meters)." },
    { "name": "radius", "type": "number", "label": "半径", "default": 0.2, "description": "柱身半径（方柱为半边长）", "description-en": "Shaft radius (half side for square)." },
    { "name": "shape", "type": "string", "label": "截面", "default": "round", "description": "round 圆柱 / square 方柱", "description-en": "round / square shaft." },
    { "name": "base_height", "type": "number", "required": false, "label": "柱础高", "default": 0, "description": "柱础方板高度，0=无", "description-en": "Plinth/base height, 0 = none." },
    { "name": "capital_height", "type": "number", "required": false, "label": "柱头高", "default": 0, "description": "柱头方板高度，0=无", "description-en": "Capital height, 0 = none." },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "", "description": "自定义 id；空 = 自动 col{n}", "description-en": "Custom id; empty = auto col{n}." }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何", "description": "追加 column 行后的 Geometry", "description-en": "Geometry after appending the column." },
    { "name": "id", "type": "string", "label": "id", "description": "本行 shape 的 id", "description-en": "Id of the new shape." },
    { "name": "error", "type": "string", "label": "错误", "description": "非致命错误信息", "description-en": "Non-fatal error string." }
  ],
  "projectTypes": ["asset3d"]
}
