{
  "id": "g_stairs",
  "label": "楼梯",
  "name-en": "GStairs",
  "description": "追加 stairs(...)：type=straight 直梯段 / spiral 螺旋梯。当 prompt 提到 楼梯 / 台阶 / 梯段 / 螺旋楼梯 / 旋转楼梯 / stairs / steps / spiral staircase 时使用。",
  "description-en": "Append `stairs(...)` — type=straight (stepped boxes) or spiral (treads around a center pole). Use for stairs, steps, staircase, spiral staircase.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "architecture", "stairs", "cad"],
  "tag_labels": ["几何", "建筑", "楼梯", "CAD"],
  "principal": "geometry",
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何", "description": "上游 Geometry；缺省视为空", "description-en": "Upstream Geometry; empty when absent." },
    { "name": "total_rise", "type": "number", "label": "总高", "default": 2.8, "description": "总爬升高度（Z，米）", "description-en": "Total rise along Z (meters)." },
    { "name": "run", "type": "number", "label": "踏步进深", "default": 0.28, "description": "每级踏步进深（X，米）", "description-en": "Tread run per step along X." },
    { "name": "width", "type": "number", "label": "梯宽", "default": 1.0, "description": "梯段宽（Y，米）", "description-en": "Stair width along Y." },
    { "name": "step_count", "type": "number", "label": "踏步数", "default": 14, "description": "踏步数量", "description-en": "Number of steps." },
    { "name": "type", "type": "string", "required": false, "label": "类型", "default": "straight", "description": "straight 直梯 / spiral 螺旋梯", "description-en": "straight / spiral." },
    { "name": "radius", "type": "number", "required": false, "label": "螺旋外半径", "default": 1.2, "description": "spiral：踏步外半径（米）", "description-en": "spiral: outer tread radius." },
    { "name": "inner_radius", "type": "number", "required": false, "label": "中柱半径", "default": 0.15, "description": "spiral：中柱半径（米）", "description-en": "spiral: center pole radius." },
    { "name": "sweep_deg", "type": "number", "required": false, "label": "旋转角", "default": 270, "description": "spiral：总旋转角（度）", "description-en": "spiral: total sweep angle (deg)." },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "", "description": "自定义 id；空 = 自动 stair{n}", "description-en": "Custom id; empty = auto stair{n}." }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何", "description": "追加 stairs 行后的 Geometry", "description-en": "Geometry after appending the stairs." },
    { "name": "id", "type": "string", "label": "id", "description": "本行 shape 的 id", "description-en": "Id of the new shape." },
    { "name": "error", "type": "string", "label": "错误", "description": "非致命错误信息", "description-en": "Non-fatal error string." }
  ],
  "projectTypes": ["asset3d"]
}
