{
  "id": "g_facade_panel",
  "label": "外墙挂板",
  "name-en": "GFacadePanel",
  "description": "追加 facade_panel(...)：外立面挂板 / siding 薄板，可带水平 reveal 板缝阵列。当 prompt 提到 外墙板 / 挂板 / 壁板 / siding / cladding 时使用。",
  "description-en": "Append `facade_panel(...)` — exterior cladding/siding sheet with optional horizontal reveal grooves. Use for siding, cladding, facade panel.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "architecture", "facade", "cad"],
  "tag_labels": ["几何", "建筑", "外立面", "CAD"],
  "principal": "geometry",
  "inputs": [
    { "name": "geometry", "type": "geometry", "required": false, "label": "几何", "description": "上游 Geometry；缺省视为空", "description-en": "Upstream Geometry; empty when absent." },
    { "name": "panel_w", "type": "number", "label": "板宽", "default": 2.4, "description": "板宽（X，米）", "description-en": "Panel width along X (meters)." },
    { "name": "panel_h", "type": "number", "label": "板高", "default": 2.8, "description": "板高（Y，米）", "description-en": "Panel height along Y (meters)." },
    { "name": "thickness", "type": "number", "label": "板厚", "default": 0.03, "description": "板厚（Z，米）", "description-en": "Thickness along Z (meters)." },
    { "name": "groove_count", "type": "number", "required": false, "label": "板缝数", "default": 6, "description": "横向 reveal 板缝数量；0=平板", "description-en": "Horizontal reveal grooves; 0 = flat sheet." },
    { "name": "groove_depth", "type": "number", "required": false, "label": "板缝深", "default": 0, "description": "板缝深度；0=默认 0.4×厚", "description-en": "Groove depth; 0 = 0.4×thickness." },
    { "name": "groove_width", "type": "number", "required": false, "label": "板缝宽", "default": 0, "description": "板缝宽度；0=自动", "description-en": "Groove width; 0 = auto." },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "", "description": "自定义 id；空 = 自动 facade{n}", "description-en": "Custom id; empty = auto facade{n}." }
  ],
  "outputs": [
    { "name": "geometry", "type": "geometry", "label": "几何", "description": "追加 facade_panel 行后的 Geometry", "description-en": "Geometry after appending the facade panel." },
    { "name": "id", "type": "string", "label": "id", "description": "本行 shape 的 id", "description-en": "Id of the new shape." },
    { "name": "error", "type": "string", "label": "错误", "description": "非致命错误信息", "description-en": "Non-fatal error string." }
  ],
  "projectTypes": ["asset3d"]
}
