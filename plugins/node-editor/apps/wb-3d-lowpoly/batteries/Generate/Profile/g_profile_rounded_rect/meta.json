    { "name": "radius", "type": "number", "label": "圆角半径", "default": 0.1 },
    { "name": "segments", "type": "number", "label": "圆角段数", "default": 8 },
    { "name": "id", "type": "string", "required": false, "label": "id", "default": "" }
