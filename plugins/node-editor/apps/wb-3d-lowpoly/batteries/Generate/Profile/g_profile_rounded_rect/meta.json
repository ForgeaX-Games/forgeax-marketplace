{
  "id": "g_profile_rounded_rect",
  "label": "圆角矩形 Profile",
  "name-en": "GProfileRoundedRect",
  "description": "创建位于 XY 平面的圆角矩形 profile。",
  "description-en": "Create a rounded rectangle profile in the XY plane.",
  "version": "1.0.0",
  "autoIterate": true,
  "tags": ["geometry", "profile", "csg", "cad"],
