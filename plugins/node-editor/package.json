{
  "name": "forgeax-wb-node-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Node-editor monorepo: shared runtime kernel + editor-host + the wb-3d-lowpoly and wb-scene-generator workbench plugins",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "apps/*/backend",
    "apps/*/frontend"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:vendor": "pnpm --filter './apps/*/backend' run --if-present build:vendor",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "pretypecheck": "pnpm --filter './packages/**' run --if-present build && pnpm build:vendor",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.0.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "prettier": "^3.0.0"
  }
}
