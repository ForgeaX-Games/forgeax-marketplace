{
  "name": "@forgeax/editor-host",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared, app-agnostic node-editor host helpers reused by the wb-3d-lowpoly and wb-scene-generator backends",
  "exports": {
    "./backend": {
      "source": "./src/backend/index.ts",
      "types": "./dist/backend/index.d.ts",
      "import": "./dist/backend/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepare": "tsc -b"
  },
  "dependencies": {
    "@forgeax/batteries-common": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20.19"
  }
}
