{
  "name": "@forgeax/node-runtime-react",
  "version": "0.5.0",
  "description": "React 18 node-programming editor for ForgeaX (faithful <Editor> + stores at the ./editor entry; API-contract types at the . entry).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js"
    },
    "./styles.css": "./src/styles/legacy.css",
    "./editor.css": "./src/editor/styles/design-system.css"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b && node scripts/copy-css.mjs",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepare": "tsc -b && node scripts/copy-css.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "reactflow": "^11.0.0",
    "zustand": "^4.0.0"
  },
  "dependencies": {
    "@forgeax/node-runtime": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.60.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "reactflow": "^11.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^3.0.0",
    "zustand": "^4.0.0"
  }
}
