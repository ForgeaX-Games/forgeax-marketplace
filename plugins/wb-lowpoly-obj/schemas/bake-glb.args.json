{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "lowpoly:bake-glb args",
  "type": "object",
  "additionalProperties": false,
  "required": ["gameSlug", "slug"],
  "properties": {
    "gameSlug": { "type": "string" },
    "slug": { "type": "string" },
    "includeClips": {
      "type": "boolean",
      "default": true,
      "description": "When false, only bind-pose mesh + skeleton are emitted (smaller .glb)."
    }
  }
}
